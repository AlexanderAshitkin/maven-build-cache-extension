<!--
  Parameter catalog for maven-rar-plugin.
  Source: https://maven.apache.org/plugins/maven-rar-plugin/
  Latest documented version: 3.0.0

  category values:
    functional  - affects artifact content (which files end up in the RAR,
                  ra.xml content, archive structure)
    behavioral  - affects how packaging runs but not the output artifact

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-rar-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  rar:rar                                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>rar</name>
      <fullName>org.apache.maven.plugins:maven-rar-plugin:rar</fullName>
      <description>Builds a RAR (Resource Adapter aRchive) from the project sources and dependencies.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Source directory ──────────────────────────────────────── -->
        <parameter>
          <name>rarSourceDirectory</name>
          <description>Directory containing RAR source files (ra.xml, supporting descriptors, etc.). Default: ${basedir}/src/main/rar</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${basedir}/src/main/rar</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Output ────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the generated RAR file is placed. Default: ${project.build.directory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>finalName</name>
          <description>Base name of the generated RAR file. Default: ${project.build.finalName}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.finalName}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>classifier</name>
          <description>Classifier appended to the RAR artifact name.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Content inclusion / exclusion ────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns for files to include from the rarSourceDirectory.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns for files to exclude from the rarSourceDirectory.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── RA descriptor ─────────────────────────────────────────── -->
        <parameter>
          <name>raXmlFile</name>
          <description>Path to the ra.xml deployment descriptor. Default: ${basedir}/src/main/rar/META-INF/ra.xml</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${basedir}/src/main/rar/META-INF/ra.xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Archive / packaging ───────────────────────────────────── -->
        <parameter>
          <name>archive</name>
          <description>Maven Archiver configuration for the RAR archive (manifest, compression, index).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>MavenArchiveConfiguration</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>includeJar</name>
          <description>Whether to include the generated project JAR inside the RAR archive. Default: true</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>workDirectory</name>
          <description>Staging directory where the exploded RAR content is assembled. Default: ${project.build.directory}/rar</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/rar</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Reproducible builds ───────────────────────────────────── -->
        <parameter>
          <name>outputTimestamp</name>
          <description>Timestamp for reproducible archive entries (ISO 8601 date-time or seconds since epoch). User property: project.build.outputTimestamp. Default: ${project.build.outputTimestamp}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.outputTimestamp}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the RAR packaging goal. User property: maven.rar.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.4,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  rar:help                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-rar-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. Default: 80</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. Default: 2</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
