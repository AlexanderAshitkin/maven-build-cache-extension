<!--
  Parameter catalog for maven-changelog-plugin.
  Source: https://maven.apache.org/plugins/maven-changelog-plugin/
  Latest documented version: 2.3

  category values:
    functional  - affects report content/output (cache must be invalidated on change)
    behavioral  - affects how the goal runs but not the output artifacts

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-changelog-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  changelog:changelog                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>changelog</name>
      <fullName>org.apache.maven.plugins:maven-changelog-plugin:changelog</fullName>
      <description>Generates a changelog report from SCM history.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Source / output directories ───────────────────────────── -->
        <parameter>
          <name>basedir</name>
          <description>Base directory of the project used as SCM checkout root. User property: basedir</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${basedir}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the changelog report is written. User property: project.reporting.outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Encoding ───────────────────────────────────────────────── -->
        <parameter>
          <name>outputEncoding</name>
          <description>Encoding used for the generated report files. User property: outputEncoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.reporting.outputEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>inputEncoding</name>
          <description>Encoding used when reading SCM changelog output. User property: inputEncoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.sourceEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>

        <!-- ── SCM query type / range ─────────────────────────────────── -->
        <parameter>
          <name>type</name>
          <description>Type of changelog query: range, date, or tag. User property: changelog.type</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>range</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>range</name>
          <description>Number of days (type=range) or number of revisions to include. User property: changelog.range</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>30</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>dates</name>
          <description>Date range for SCM query when type=date (format: yyyy-MM-dd). User property: changelog.dates</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>tags</name>
          <description>SCM tag names defining the revision range when type=tag. User property: changelog.tags</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── SCM connection ─────────────────────────────────────────── -->
        <parameter>
          <name>connectionType</name>
          <description>SCM connection type to use: connection or developerConnection. User property: changelog.connectionType</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>connection</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Date / heading formatting ──────────────────────────────── -->
        <parameter>
          <name>dateFormat</name>
          <description>Date format pattern used when parsing SCM date output. User property: changelog.dateFormat</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>yyyy-MM-dd</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>headingDateFormat</name>
          <description>Date format pattern used in section headings of the report. User property: changelog.headingDateFormat</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>yyyy-MM-dd</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Issue linking ──────────────────────────────────────────── -->
        <parameter>
          <name>issueIDRegexPattern</name>
          <description>Regex pattern to detect issue IDs in commit messages. User property: changelog.issueIDRegexPattern</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>[a-zA-Z]{2,}-\d+</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>issueLinkUrl</name>
          <description>URL template for linking issue IDs; %ISSUE% is replaced with the matched ID. User property: changelog.issueLinkUrl</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>

        <!-- ── Cross-reference / display URLs ────────────────────────── -->
        <parameter>
          <name>displayFileDetailUrl</name>
          <description>URL template for per-file SCM browser links; %FILE% replaced with file path. User property: changelog.displayFileDetailUrl</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>displayChangeSetDetailUrl</name>
          <description>URL template for changeset browser links; %REV% replaced with revision. User property: changelog.displayChangeSetDetailUrl</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>displayFileRevDetailUrl</name>
          <description>URL template for file-revision browser links. User property: changelog.displayFileRevDetailUrl</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Report options ─────────────────────────────────────────── -->
        <parameter>
          <name>linkXRef</name>
          <description>Link source cross-references to JXR report when available. User property: linkXRef</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

