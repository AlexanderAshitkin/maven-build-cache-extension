        <parameter>
          <name>url</name>
          <description>JDBC URL of the database to repair. User property: flyway.url</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the repair goal entirely. User property: flyway.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

