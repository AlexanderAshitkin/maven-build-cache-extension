    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>info</name>
      <fullName>org.flywaydb:flyway-maven-plugin:info</fullName>
      <description>Prints the status of all migrations including applied and pending ones.</description>
      <versionRange>[5.0,)</versionRange>
      <parameters>

        <parameter>
          <name>url</name>
          <description>JDBC URL of the database to inspect. User property: flyway.url</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>
        <parameter>
          <name>locations</name>
          <description>Locations to scan for migration scripts. User property: flyway.locations</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the info goal entirely. User property: flyway.skip</description>
          <category>behavioral</category>
