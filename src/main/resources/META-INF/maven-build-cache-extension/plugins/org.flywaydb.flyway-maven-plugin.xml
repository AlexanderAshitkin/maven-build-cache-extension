    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>validate</name>
      <fullName>org.flywaydb:flyway-maven-plugin:validate</fullName>
      <description>Validates that the applied migrations match the available migration scripts.</description>
      <versionRange>[5.0,)</versionRange>
      <parameters>

        <parameter>
          <name>url</name>
          <description>JDBC URL of the database to validate against. User property: flyway.url</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>
        <parameter>
          <name>locations</name>
          <description>Locations to scan for migration scripts to validate against. User property: flyway.locations</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>
        <parameter>
          <name>ignoreMigrationPatterns</name>
          <description>Comma-separated list of migration state patterns to ignore during validation. User property: flyway.ignoreMigrationPatterns</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[8.2,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the validate goal entirely. User property: flyway.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

