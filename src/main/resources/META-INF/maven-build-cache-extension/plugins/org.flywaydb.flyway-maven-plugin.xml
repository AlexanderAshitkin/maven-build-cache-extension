    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  flyway:baseline                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>baseline</name>
      <fullName>org.flywaydb:flyway-maven-plugin:baseline</fullName>
      <description>Baselines an existing database, marking it as already having been migrated to baselineVersion.</description>
      <versionRange>[5.0,)</versionRange>
      <parameters>

        <parameter>
          <name>url</name>
          <description>JDBC URL of the database to baseline. User property: flyway.url</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>
        <parameter>
          <name>baselineVersion</name>
          <description>Version to tag the baseline with. User property: flyway.baselineVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>1</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>
        <parameter>
          <name>baselineDescription</name>
          <description>Description for the baseline entry in the schema history table. User property: flyway.baselineDescription</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the baseline goal entirely. User property: flyway.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[5.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

