<!--
  Parameter catalog for maven-deploy-plugin.
  Source: https://maven.apache.org/plugins/maven-deploy-plugin/
  Latest documented version: 3.1.4

  category values:
    functional  - affects artifact coordinates or content that is deployed to the
                  remote repository
    behavioral  - affects how or when deployment runs, not the artifact content

  envSpecific: true if the parameter commonly carries repository URLs, server IDs,
               or file-system paths that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-deploy-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  deploy:deploy                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>deploy</name>
      <fullName>org.apache.maven.plugins:maven-deploy-plugin:deploy</fullName>
      <description>Deploy project artifacts to the remote repository defined in distributionManagement.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Execution control ─────────────────────────────────────── -->
        <parameter>
          <name>deployAtEnd</name>
          <description>Defer deployment of all reactor projects until the end of the multimodule build instead of deploying during each project's deploy phase. User property: deployAtEnd</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.8,)</versionRange>
        </parameter>
        <parameter>
          <name>retryFailedDeploymentCount</name>
          <description>Number of times to retry a failed deployment before giving up (range: 1–10). User property: retryFailedDeploymentCount</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>1</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.7,)</versionRange>
        </parameter>
        <parameter>
          <name>allowIncompleteProjects</name>
          <description>Allow deployment of projects with non-pom packaging that have no main artifact. User property: allowIncompleteProjects</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.1,)</versionRange>
        </parameter>

        <!-- ── Alternative repositories ──────────────────────────────── -->
        <parameter>
          <name>altDeploymentRepository</name>
          <description>Alternative repository for all artifacts, overriding distributionManagement. Format: id::url. User property: altDeploymentRepository</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>altReleaseDeploymentRepository</name>
          <description>Alternative repository for release versions only, overriding distributionManagement. Format: id::url. User property: altReleaseDeploymentRepository</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.8,)</versionRange>
        </parameter>
        <parameter>
          <name>altSnapshotDeploymentRepository</name>
          <description>Alternative repository for snapshot versions only, overriding distributionManagement. Format: id::url. User property: altSnapshotDeploymentRepository</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.8,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip deployment. Accepts true, false, releases, or snapshots to selectively disable deployment. User property: maven.deploy.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.4,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  deploy:deploy-file                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>deploy-file</name>
      <fullName>org.apache.maven.plugins:maven-deploy-plugin:deploy-file</fullName>
      <description>Deploy a pre-built artifact to a remote repository with explicit coordinates, optionally generating a POM.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Required ───────────────────────────────────────────────── -->
        <parameter>
          <name>file</name>
          <description>The file to deploy (required). User property: file</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>url</name>
          <description>URL of the remote repository to deploy to (required). User property: url</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>repositoryId</name>
          <description>Server ID that maps to credentials in settings.xml for the target repository. Default: remote-repository. User property: repositoryId</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <defaultValue>remote-repository</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Artifact coordinates ──────────────────────────────────── -->
        <parameter>
          <name>groupId</name>
          <description>GroupId of the artifact to deploy. Retrieved from an embedded POM when not set. User property: groupId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>artifactId</name>
          <description>ArtifactId of the artifact to deploy. Retrieved from an embedded POM when not set. User property: artifactId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>version</name>
          <description>Version of the artifact to deploy. Retrieved from an embedded POM when not set. User property: version</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>packaging</name>
          <description>Packaging type of the artifact (derived from POM packaging or file extension when not set). User property: packaging</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>classifier</name>
          <description>Classifier to attach to the deployed artifact. User property: classifier</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>extension</name>
          <description>File extension for the artifact, overriding plugin auto-detection. User property: extension</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.3,)</versionRange>
        </parameter>

        <!-- ── Side artifacts ─────────────────────────────────────────── -->
        <parameter>
          <name>sources</name>
          <description>Bundled sources JAR to deploy alongside the main artifact. User property: sources</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.6,)</versionRange>
        </parameter>
        <parameter>
          <name>javadoc</name>
          <description>Bundled Javadoc JAR to deploy alongside the main artifact. User property: javadoc</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.6,)</versionRange>
        </parameter>
        <parameter>
          <name>files</name>
          <description>Comma-separated list of additional files to deploy as extra side artifacts. User property: files</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>classifiers</name>
          <description>Comma-separated list of classifiers for the extra side artifacts specified by files. User property: classifiers</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>types</name>
          <description>Comma-separated list of types for the extra side artifacts specified by files. User property: types</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── POM handling ───────────────────────────────────────────── -->
        <parameter>
          <name>pomFile</name>
          <description>Location of an existing POM file to deploy alongside the main artifact. User property: pomFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generatePom</name>
          <description>Generate and deploy a minimal POM when no pomFile is specified. User property: generatePom</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>description</name>
          <description>Description written into the generated POM (only used when generatePom=true). User property: generatePom.description</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Retry / error handling ────────────────────────────────── -->
        <parameter>
          <name>retryFailedDeploymentCount</name>
          <description>Number of times to retry a failed deployment before giving up (range: 1–10). User property: retryFailedDeploymentCount</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>1</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.7,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip deployment. Accepts true, false, releases, or snapshots to selectively disable deployment. User property: maven.deploy.file.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  deploy:help                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-deploy-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[2.5,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
