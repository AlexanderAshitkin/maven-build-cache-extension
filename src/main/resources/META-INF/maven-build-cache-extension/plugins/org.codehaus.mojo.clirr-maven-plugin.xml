<!--
  Parameter catalog for clirr-maven-plugin.
  Source: https://www.mojohaus.org/clirr-maven-plugin/
  Latest documented version: 2.8

  category values:
    functional  - affects which classes are compared and what constitutes a
                  violation; changes the reported differences and build outcome
    behavioral  - affects how the goal runs but not the comparison results

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.codehaus.mojo</groupId>
  <artifactId>clirr-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  clirr:check                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>check</name>
      <fullName>org.codehaus.mojo:clirr-maven-plugin:check</fullName>
      <description>Checks for binary and source compatibility issues between current code and a baseline artifact, forking a new lifecycle.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Comparison target ──────────────────────────────────────── -->
        <parameter>
          <name>comparisonArtifacts</name>
          <description>List of GAV descriptors identifying baseline artifacts to compare against. Overrides comparisonVersion.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>comparisonVersion</name>
          <description>Version of the current project artifact to use as the comparison baseline. User property: comparisonVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>LATEST</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Severity and failure control ──────────────────────────── -->
        <parameter>
          <name>minSeverity</name>
          <description>Minimum severity level to report: info, warning, error. User property: minSeverity</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>warning</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>failOnWarning</name>
          <description>Fail the build if any warnings (or errors) are found. User property: failOnWarning</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>failOnError</name>
          <description>Fail the build if any binary-incompatible errors are found. User property: failOnError</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Class filtering ────────────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns of class names to include in the comparison (default: all classes).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns of class names to exclude from the comparison.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Ignored differences ────────────────────────────────────── -->
        <parameter>
          <name>ignored</name>
          <description>List of specific API differences to ignore (by difference code and affected class/method).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>ignoredDifferencesFile</name>
          <description>Path to an XML file listing API differences to ignore. User property: ignoredDifferencesFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>

        <!-- ── Source / encoding ──────────────────────────────────────── -->
        <parameter>
          <name>sourceDirectory</name>
          <description>Directory containing the current project's compiled classes for comparison. User property: sourceDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>encoding</name>
          <description>Source file encoding used when generating the HTML or text report. User property: encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.reporting.outputEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Output files ───────────────────────────────────────────── -->
        <parameter>
          <name>textOutputFile</name>
          <description>File path for the plain-text Clirr report. User property: textOutputFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>xmlOutputFile</name>
          <description>File path for the XML Clirr report. User property: xmlOutputFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>htmlOutputFile</name>
          <description>File path for the HTML Clirr report. User property: htmlOutputFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip Clirr execution entirely. User property: clirr.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  clirr:check-no-fork                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>check-no-fork</name>
      <fullName>org.codehaus.mojo:clirr-maven-plugin:check-no-fork</fullName>
      <description>Checks for API compatibility issues without forking a new lifecycle (assumes classes are already compiled).</description>
      <versionRange>[2.2,)</versionRange>
      <parameters>

        <parameter>
          <name>comparisonArtifacts</name>
          <description>List of GAV descriptors identifying baseline artifacts to compare against. Overrides comparisonVersion.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>comparisonVersion</name>
          <description>Version of the current project artifact to use as the comparison baseline. User property: comparisonVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>LATEST</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>minSeverity</name>
          <description>Minimum severity level to report: info, warning, error. User property: minSeverity</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>warning</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>failOnWarning</name>
          <description>Fail the build if any warnings (or errors) are found. User property: failOnWarning</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>failOnError</name>
          <description>Fail the build if any binary-incompatible errors are found. User property: failOnError</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns of class names to include in the comparison (default: all classes).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns of class names to exclude from the comparison.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>ignored</name>
          <description>List of specific API differences to ignore (by difference code and affected class/method).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>ignoredDifferencesFile</name>
          <description>Path to an XML file listing API differences to ignore. User property: ignoredDifferencesFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>sourceDirectory</name>
          <description>Directory containing the compiled classes to compare. User property: sourceDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>textOutputFile</name>
          <description>File path for the plain-text Clirr report. User property: textOutputFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>xmlOutputFile</name>
          <description>File path for the XML Clirr report. User property: xmlOutputFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip Clirr execution entirely. User property: clirr.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  clirr:clirr (report goal)                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>clirr</name>
      <fullName>org.codehaus.mojo:clirr-maven-plugin:clirr</fullName>
      <description>Generates a Clirr report as part of the Maven site.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>comparisonArtifacts</name>
          <description>List of GAV descriptors identifying baseline artifacts to compare against.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>comparisonVersion</name>
          <description>Version of the current project artifact to use as the comparison baseline. User property: comparisonVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>LATEST</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>minSeverity</name>
          <description>Minimum severity level to include in the report: info, warning, error. User property: minSeverity</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>warning</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns of class names to include in the comparison.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns of class names to exclude from the comparison.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>ignored</name>
          <description>List of specific API differences to ignore in the report.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>sourceDirectory</name>
          <description>Directory containing the compiled classes for comparison. User property: sourceDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>encoding</name>
          <description>Character encoding for the generated report. User property: encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.reporting.outputEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>linkXRef</name>
          <description>Create links to the source cross-reference report in the Clirr report. User property: linkXRef</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip generating the Clirr report. User property: clirr.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  clirr:help                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.codehaus.mojo:clirr-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. User property: detail</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help. User property: goal</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. User property: lineLength</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. User property: indentSize</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
