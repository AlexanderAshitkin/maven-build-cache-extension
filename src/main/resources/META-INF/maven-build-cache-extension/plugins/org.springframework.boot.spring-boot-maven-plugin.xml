<!--
  Parameter catalog for spring-boot-maven-plugin.
  Source: https://docs.spring.io/spring-boot/docs/current/maven-plugin/reference/htmlsingle/
  Latest documented version: 3.4.x

  category values:
    functional  - affects the repackaged JAR/WAR or build-info output content
    behavioral  - affects how the goal runs but not the packaged artifact content

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.springframework.boot</groupId>
  <artifactId>spring-boot-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  spring-boot:repackage                                              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>repackage</name>
      <fullName>org.springframework.boot:spring-boot-maven-plugin:repackage</fullName>
      <description>Repackages existing JAR/WAR archive into a self-contained executable Spring Boot archive.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Output artifact ───────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the repackaged archive is written. User property: project.build.directory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>finalName</name>
          <description>Base name (without extension) of the repackaged archive. User property: project.build.finalName</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.finalName}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>classifier</name>
          <description>Classifier suffix appended to the repackaged artifact name (e.g. exec). User property: spring-boot.repackage.classifier</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>attach</name>
          <description>Attach the repackaged archive as a project artifact in addition to the original. User property: spring-boot.repackage.attach</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Archive layout ─────────────────────────────────────────── -->
        <parameter>
          <name>layout</name>
          <description>Archive layout type: JAR, WAR, ZIP, DIR, NONE. Determines loader strategy. User property: spring-boot.repackage.layout</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>layoutFactory</name>
          <description>Custom LayoutFactory implementation class to use instead of the built-in layouts.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>LayoutFactory</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.5,)</versionRange>
        </parameter>
        <parameter>
          <name>layers</name>
          <description>Layered JAR configuration controlling how application layers are ordered and written.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Layers</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.3,)</versionRange>
        </parameter>

        <!-- ── Main class ─────────────────────────────────────────────── -->
        <parameter>
          <name>mainClass</name>
          <description>Fully-qualified main class name embedded into the manifest. Auto-detected if not set. User property: spring-boot.run.main-class</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Dependency filtering ───────────────────────────────────── -->
        <parameter>
          <name>excludes</name>
          <description>Artifact coordinates (groupId:artifactId) to exclude from the repackaged archive.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludeGroupIds</name>
          <description>Comma-separated list of groupIds whose artifacts are excluded from repackaging. User property: spring-boot.excludeGroupIds</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.1,)</versionRange>
        </parameter>
        <parameter>
          <name>excludeArtifactIds</name>
          <description>Comma-separated list of artifactIds to exclude from repackaging. User property: spring-boot.excludeArtifactIds</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.1,)</versionRange>
        </parameter>
        <parameter>
          <name>includeSystemScope</name>
          <description>Include system-scoped dependencies in the repackaged archive. User property: spring-boot.includeSystemScope</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.4,)</versionRange>
        </parameter>

        <!-- ── Executable JAR ─────────────────────────────────────────── -->
        <parameter>
          <name>executable</name>
          <description>Make the resulting JAR directly executable on Unix (prepends a launch script). User property: spring-boot.repackage.executable</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>embeddedLaunchScript</name>
          <description>Custom launch script file to embed when executable=true.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>embeddedLaunchScriptProperties</name>
          <description>Properties to expand inside the embedded launch script template.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Properties</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>

        <!-- ── Reproducible builds ───────────────────────────────────── -->
        <parameter>
          <name>outputTimestamp</name>
          <description>Timestamp for reproducible archive entries (ISO 8601 or epoch seconds). User property: project.build.outputTimestamp</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.3,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip repackaging entirely. User property: spring-boot.repackage.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  spring-boot:build-info                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>build-info</name>
      <fullName>org.springframework.boot:spring-boot-maven-plugin:build-info</fullName>
      <description>Generates a build-info.properties file for use by Spring Boot Actuator.</description>
      <versionRange>[1.3,)</versionRange>
      <parameters>

        <parameter>
          <name>outputFile</name>
          <description>Path of the generated build-info.properties file. User property: spring-boot.build-info.outputFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}/META-INF/build-info.properties</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>additionalProperties</name>
          <description>Additional key/value pairs written into the build-info.properties file.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>excludeInfoProperties</name>
          <description>Standard build properties to omit from the generated file (e.g. time, group).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.6,)</versionRange>
        </parameter>
        <parameter>
          <name>time</name>
          <description>Override for the build.time property (ISO 8601). Set to 'off' to omit. User property: project.build.outputTimestamp</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip build-info generation entirely. User property: spring-boot.build-info.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.6,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  spring-boot:run                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>run</name>
      <fullName>org.springframework.boot:spring-boot-maven-plugin:run</fullName>
      <description>Runs the Spring Boot application in-process using the current project classpath.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>mainClass</name>
          <description>Fully-qualified main class to run (auto-detected if not set). User property: spring-boot.run.main-class</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>arguments</name>
          <description>Application arguments passed to main(). User property: spring-boot.run.arguments</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>profiles</name>
          <description>Spring profiles to activate (sets spring.profiles.active). User property: spring-boot.run.profiles</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>jvmArguments</name>
          <description>JVM arguments forwarded to the forked process. User property: spring-boot.run.jvmArguments</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>workingDirectory</name>
          <description>Working directory used when launching the application. User property: spring-boot.run.workingDirectory</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>addResources</name>
          <description>Add Maven resources to the classpath for hot-reload during development. User property: spring-boot.run.addResources</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip running the application. User property: spring-boot.run.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  spring-boot:start / spring-boot:stop                              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>start</name>
      <fullName>org.springframework.boot:spring-boot-maven-plugin:start</fullName>
      <description>Starts the Spring Boot application in a background process for integration testing.</description>
      <versionRange>[1.3,)</versionRange>
      <parameters>

        <parameter>
          <name>mainClass</name>
          <description>Fully-qualified main class to start. User property: spring-boot.run.main-class</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>arguments</name>
          <description>Application arguments passed to main(). User property: spring-boot.run.arguments</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>jvmArguments</name>
          <description>JVM arguments forwarded to the forked process. User property: spring-boot.run.jvmArguments</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip starting the application. User property: spring-boot.run.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <goal>
      <name>stop</name>
      <fullName>org.springframework.boot:spring-boot-maven-plugin:stop</fullName>
      <description>Stops a Spring Boot application previously started with spring-boot:start.</description>
      <versionRange>[1.3,)</versionRange>
      <parameters>

        <parameter>
          <name>skip</name>
          <description>Skip stopping the application. User property: spring-boot.run.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  spring-boot:build-image                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>build-image</name>
      <fullName>org.springframework.boot:spring-boot-maven-plugin:build-image</fullName>
      <description>Packages the application into an OCI image using Cloud Native Buildpacks.</description>
      <versionRange>[2.3,)</versionRange>
      <parameters>

        <parameter>
          <name>image</name>
          <description>Image configuration: name, builder, run image, buildpacks, environment, tags, publish settings.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Image</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.3,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip OCI image build. User property: spring-boot.build-image.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.3,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  spring-boot:help                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.springframework.boot:spring-boot-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
