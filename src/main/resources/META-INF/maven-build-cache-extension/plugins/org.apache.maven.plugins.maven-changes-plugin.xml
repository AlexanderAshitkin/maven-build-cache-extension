          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>columnNames</name>
          <description>Comma-separated column names to display in the JIRA report table.</description>
          <category>functional</category>
