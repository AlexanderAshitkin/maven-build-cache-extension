<!--
  Parameter catalog for maven-changes-plugin.
  Source: https://maven.apache.org/plugins/maven-changes-plugin/
  Latest documented version: 2.12.1

  category values:
    functional  - affects report content/output (cache must be invalidated on change)
    behavioral  - affects how the goal runs but not the output artifacts

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-changes-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  changes:announcement-generate                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>announcement-generate</name>
      <fullName>org.apache.maven.plugins:maven-changes-plugin:announcement-generate</fullName>
      <description>Generates a release announcement from the changes.xml file.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Output ─────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the announcement file is generated. User property: project.build.directory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/announcement</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>finalName</name>
          <description>Name of the generated announcement file without extension.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>announcement</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Template ───────────────────────────────────────────────── -->
        <parameter>
          <name>template</name>
          <description>Velocity template file name used to render the announcement.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>announcement.vm</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>templateDirectory</name>
          <description>Directory containing custom Velocity templates for announcement generation.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <defaultValue>org/apache/maven/plugin/announcement</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>templateEncoding</name>
          <description>Encoding of the Velocity template files.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.sourceEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.4,)</versionRange>
        </parameter>

        <!-- ── Version / project info ─────────────────────────────────── -->
        <parameter>
          <name>version</name>
          <description>The version of the artifact for which the announcement is generated.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.version}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>urlDownload</name>
          <description>URL where the release artifact can be downloaded; included in the announcement.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>developmentTeam</name>
          <description>Name of the development team to include in the announcement text.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.name} team</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>introduction</name>
          <description>Introductory text paragraph included at the top of the announcement.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Changes XML ────────────────────────────────────────────── -->
        <parameter>
          <name>xmlPath</name>
          <description>Path to the changes.xml file to read when generating the announcement.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${basedir}/src/changes/changes.xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>filteringChanges</name>
          <description>Apply Maven resource filtering to changes.xml before parsing.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip announcement generation entirely. User property: changes.announcement.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.4,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  changes:announcement-mail                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>announcement-mail</name>
      <fullName>org.apache.maven.plugins:maven-changes-plugin:announcement-mail</fullName>
      <description>Sends the generated release announcement by e-mail.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>announcementDirectory</name>
          <description>Directory containing the generated announcement file to mail.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/announcement</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>announcementFile</name>
          <description>Name of the announcement file to mail.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>announcement.vm</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>toAddresses</name>
          <description>List of e-mail addresses to send the announcement to.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>fromDeveloperId</name>
          <description>ID of the developer who sends the announcement (from POM developers list).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>smtpHost</name>
          <description>SMTP server host name used to send the announcement e-mail.</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>smtpPort</name>
          <description>SMTP server port used for sending e-mail. User property: changes.smtpPort</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>25</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>sslMode</name>
          <description>Enable SSL for the SMTP connection. User property: changes.sslMode</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>username</name>
          <description>Username for SMTP authentication. User property: changes.username</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>password</name>
          <description>Password for SMTP authentication. User property: changes.password</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>subject</name>
          <description>Subject line of the announcement e-mail. User property: changes.subject</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>[ANNOUNCEMENT] ${project.name} ${project.version} released</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip sending the announcement e-mail. User property: changes.announcement.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.4,)</versionRange>
        </parameter>

      </parameters>
    </goal>

