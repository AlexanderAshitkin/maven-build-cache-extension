  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  docker:build                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>build</name>
      <fullName>io.fabric8:docker-maven-plugin:build</fullName>
      <description>Builds Docker images based on the image configurations defined in the plugin configuration.</description>
      <versionRange>[0.14,)</versionRange>
      <parameters>

        <!-- ── Image configuration ────────────────────────────────────── -->
        <parameter>
          <name>images</name>
          <description>List of image configurations (name, build, alias etc.) defining images to build.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>

        <!-- ── Output ─────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory used as the base for the Docker build context temporary files. User property: docker.target.dir</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.directory}/docker</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>

        <!-- ── Registry ───────────────────────────────────────────────── -->
        <parameter>
          <name>registry</name>
          <description>Default Docker registry to prepend to image names that have no explicit registry. User property: docker.registry</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>

        <!-- ── Docker daemon ──────────────────────────────────────────── -->
        <parameter>
          <name>dockerHost</name>
          <description>URL of the Docker daemon socket (e.g. unix:///var/run/docker.sock). User property: docker.host</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>
        <parameter>
          <name>certPath</name>
          <description>Directory containing TLS certificates used to connect to the Docker daemon. User property: docker.certPath</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>

        <!-- ── Build args ─────────────────────────────────────────────── -->
        <parameter>
          <name>buildArgs</name>
          <description>Map of Docker build-arg key-value pairs passed to the Dockerfile ARG instructions. User property: docker.buildArg.*</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>

        <!-- ── Dockerfile directory ───────────────────────────────────── -->
        <parameter>
          <name>dockerFileDir</name>
          <description>Directory containing the Dockerfile; used as the build context root. User property: docker.dockerFileDir</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>

        <!-- ── Filtering ──────────────────────────────────────────────── -->
        <parameter>
          <name>filter</name>
          <description>Comma-separated list of image aliases or names to build; builds all if omitted. User property: docker.filter</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>

        <!-- ── Behavioral ─────────────────────────────────────────────── -->
        <parameter>
          <name>verbose</name>
          <description>Enable verbose output during the build. User property: docker.verbose</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>
        <parameter>
          <name>maxConnections</name>
          <description>Maximum number of parallel connections to the Docker daemon. User property: docker.maxConnections</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>100</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip all docker goals. User property: docker.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>
        <parameter>
          <name>skipBuild</name>
          <description>Skip only the docker:build goal. User property: docker.skip.build</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[0.14,)</versionRange>
        </parameter>

      </parameters>
    </goal>

