<!--
  Parameter catalog for spotless-maven-plugin.
  Source: https://github.com/diffplug/spotless/tree/main/plugin-maven
  Latest documented version: 2.44.0
-->
<plugin-catalog>
  <groupId>com.diffplug.spotless</groupId>
  <artifactId>spotless-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  spotless:check                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>check</name>
      <fullName>com.diffplug.spotless:spotless-maven-plugin:check</fullName>
      <description>Checks that all source files match the configured formatting rules; fails if not.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>java</name>
          <description>Formatting configuration for Java sources (google-java-format, eclipse, palantir, etc.).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>kotlin</name>
          <description>Formatting configuration for Kotlin sources (ktlint, diktat).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>scala</name>
          <description>Formatting configuration for Scala sources (scalafmt).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>groovy</name>
          <description>Formatting configuration for Groovy sources (eclipse formatter).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>pom</name>
          <description>Formatting configuration for pom.xml files (sortPom).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>markdown</name>
          <description>Formatting configuration for Markdown files (flexmark).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>json</name>
          <description>Formatting configuration for JSON files (gson, jackson, simple).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>yaml</name>
          <description>Formatting configuration for YAML files (jackson, snakeyaml).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>formats</name>
          <description>Generic format configurations for custom file types.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>ratchetFrom</name>
          <description>Git ref to ratchet from (only check files changed since this ref). User property: spotless.ratchetFrom</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>upToDateChecking</name>
          <description>Enable up-to-date checking to skip unchanged files. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.28,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip all Spotless processing. User property: spotless.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>checkSkip</name>
          <description>Skip only the check goal. User property: spotless.check.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  spotless:apply                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>apply</name>
      <fullName>com.diffplug.spotless:spotless-maven-plugin:apply</fullName>
      <description>Applies formatting rules to all source files, modifying them in-place.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>java</name>
          <description>Formatting configuration for Java sources.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>kotlin</name>
          <description>Formatting configuration for Kotlin sources.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>scala</name>
          <description>Formatting configuration for Scala sources.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>pom</name>
          <description>Formatting configuration for pom.xml files.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Object</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>formats</name>
          <description>Generic format configurations for custom file types.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>ratchetFrom</name>
          <description>Git ref to ratchet from (only format files changed since this ref).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip all Spotless processing. User property: spotless.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>applySkip</name>
          <description>Skip only the apply goal. User property: spotless.apply.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  spotless:help                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>com.diffplug.spotless:spotless-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. Default: 80</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. Default: 2</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
