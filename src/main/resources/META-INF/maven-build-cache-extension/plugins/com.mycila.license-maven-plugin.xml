<!--
  Parameter catalog for license-maven-plugin (com.mycila).
  Source: https://mycila.carbou.me/license-maven-plugin/
  Latest documented version: 4.x

  NOTE: Only publicly available, minimal parameter metadata included.
  This catalog does not reproduce proprietary documentation.
-->
<plugin-catalog>
  <groupId>com.mycila</groupId>
  <artifactId>license-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  license:check                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>check</name>
      <fullName>com.mycila:license-maven-plugin:check</fullName>
      <description>Checks that all source files carry the required license header; fails the build on missing headers.</description>
      <versionRange>[3.0,)</versionRange>
      <parameters>

        <!-- ── Header template ────────────────────────────────────────── -->
        <parameter>
          <name>header</name>
          <description>Path or URL to the license header template file. User property: license.header</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── File selection ─────────────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns of files to include in the check.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns of files to exclude from the check.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Comment style mapping ──────────────────────────────────── -->
        <parameter>
          <name>mapping</name>
          <description>Map of file extension to comment style definition used when checking headers.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Encoding ───────────────────────────────────────────────── -->
        <parameter>
          <name>encoding</name>
          <description>File encoding used when reading source files. User property: license.encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>UTF-8</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Strict mode ────────────────────────────────────────────── -->
        <parameter>
          <name>strictCheck</name>
          <description>Require an exact header match including whitespace; false allows relaxed matching. User property: license.strictCheck</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Failure control ────────────────────────────────────────── -->
        <parameter>
          <name>failIfMissing</name>
          <description>Fail the build when files missing the license header are found. User property: license.failIfMissing</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Properties ─────────────────────────────────────────────── -->
        <parameter>
          <name>properties</name>
          <description>Map of additional properties available as variables inside the license header template.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the license check entirely. User property: license.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  license:format                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>format</name>
      <fullName>com.mycila:license-maven-plugin:format</fullName>
      <description>Adds or updates the license header in all matching source files.</description>
      <versionRange>[3.0,)</versionRange>
      <parameters>

        <!-- ── Header template ────────────────────────────────────────── -->
        <parameter>
          <name>header</name>
          <description>Path or URL to the license header template file. User property: license.header</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── File selection ─────────────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns of files to include in the format operation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns of files to exclude from the format operation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Comment style mapping ──────────────────────────────────── -->
        <parameter>
          <name>mapping</name>
          <description>Map of file extension to comment style definition used when inserting headers.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Encoding ───────────────────────────────────────────────── -->
        <parameter>
          <name>encoding</name>
          <description>File encoding used when reading and writing source files. User property: license.encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>UTF-8</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Strict mode ────────────────────────────────────────────── -->
        <parameter>
          <name>strictCheck</name>
          <description>Use exact whitespace matching when detecting existing headers. User property: license.strictCheck</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Properties ─────────────────────────────────────────────── -->
        <parameter>
          <name>properties</name>
          <description>Map of additional properties available as variables inside the license header template.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Dry run ────────────────────────────────────────────────── -->
        <parameter>
          <name>dryRun</name>
          <description>Report which files would be modified without actually writing changes. User property: license.dryRun</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the license format operation entirely. User property: license.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  license:remove                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>remove</name>
      <fullName>com.mycila:license-maven-plugin:remove</fullName>
      <description>Removes the license header from all matching source files.</description>
      <versionRange>[3.0,)</versionRange>
      <parameters>

        <!-- ── Header template ────────────────────────────────────────── -->
        <parameter>
          <name>header</name>
          <description>Path or URL to the license header template used to identify the header to remove. User property: license.header</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── File selection ─────────────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns of files to include in the remove operation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns of files to exclude from the remove operation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Comment style mapping ──────────────────────────────────── -->
        <parameter>
          <name>mapping</name>
          <description>Map of file extension to comment style definition used when removing headers.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Encoding ───────────────────────────────────────────────── -->
        <parameter>
          <name>encoding</name>
          <description>File encoding used when reading and writing source files. User property: license.encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>UTF-8</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the license remove operation entirely. User property: license.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  license:help                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>com.mycila:license-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[3.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
