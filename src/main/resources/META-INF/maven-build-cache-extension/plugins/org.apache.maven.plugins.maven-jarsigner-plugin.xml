<!--
  Parameter catalog for maven-jarsigner-plugin.
  Source: https://maven.apache.org/plugins/maven-jarsigner-plugin/
  Latest documented version: 3.1.0
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-jarsigner-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jarsigner:sign                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>sign</name>
      <fullName>org.apache.maven.plugins:maven-jarsigner-plugin:sign</fullName>
      <description>Signs a project artifact and its attachments using jarsigner.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Keystore ──────────────────────────────────────────────── -->
        <parameter>
          <name>keystore</name>
          <description>Path to the keystore file used to sign the artifact. User property: jarsigner.keystore</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>storetype</name>
          <description>Keystore type (e.g. JKS, PKCS12). User property: jarsigner.storetype</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>storepass</name>
          <description>Password for the keystore. User property: jarsigner.storepass</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>keypass</name>
          <description>Password for the private key entry in the keystore. User property: jarsigner.keypass</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>alias</name>
          <description>Alias of the certificate in the keystore. User property: jarsigner.alias</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Output ────────────────────────────────────────────────── -->
        <parameter>
          <name>signedjar</name>
          <description>Path for the signed output JAR. If omitted, the artifact is signed in place.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Signature options ──────────────────────────────────────── -->
        <parameter>
          <name>sigfile</name>
          <description>Base name of the generated .SF and .DSA signature files. User property: jarsigner.sigfile</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>digestalg</name>
          <description>Name of the message digest algorithm used for the .SF file. User property: jarsigner.digestalg</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.2,)</versionRange>
        </parameter>
        <parameter>
          <name>sigalg</name>
          <description>Name of the signature algorithm used to sign the JAR. User property: jarsigner.sigalg</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Timestamping ──────────────────────────────────────────── -->
        <parameter>
          <name>tsa</name>
          <description>URL of the timestamping authority (TSA) to timestamp the signature. User property: jarsigner.tsa</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.2,)</versionRange>
        </parameter>
        <parameter>
          <name>tsacert</name>
          <description>Alias for the TSA's public key certificate in the keystore. User property: jarsigner.tsacert</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.2,)</versionRange>
        </parameter>
        <parameter>
          <name>tsapolicyid</name>
          <description>OID of the timestamping policy to request from the TSA. User property: jarsigner.tsapolicyid</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>

        <!-- ── Artifact selection ────────────────────────────────────── -->
        <parameter>
          <name>archiveDirectory</name>
          <description>Directory containing artifacts to sign, if signing by directory rather than project artifact.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns of artifact filenames to include in signing.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <defaultValue>**/*.jar</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns of artifact filenames to exclude from signing.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>processMainArtifact</name>
          <description>Whether to sign the main project artifact. User property: jarsigner.processMainArtifact</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.1,)</versionRange>
        </parameter>
        <parameter>
          <name>processAttachedArtifacts</name>
          <description>Whether to sign attached artifacts. User property: jarsigner.processAttachedArtifacts</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.1,)</versionRange>
        </parameter>

        <!-- ── Logging ────────────────────────────────────────────────── -->
        <parameter>
          <name>verbose</name>
          <description>Enable verbose output from jarsigner. User property: jarsigner.verbose</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the jarsigner:sign goal entirely. User property: jarsigner.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jarsigner:verify                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>verify</name>
      <fullName>org.apache.maven.plugins:maven-jarsigner-plugin:verify</fullName>
      <description>Verifies the signature of a project artifact and its attachments using jarsigner.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Keystore ──────────────────────────────────────────────── -->
        <parameter>
          <name>keystore</name>
          <description>Path to the keystore used to verify certificate chain. User property: jarsigner.keystore</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>storepass</name>
          <description>Password for the keystore used during verification. User property: jarsigner.storepass</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>alias</name>
          <description>Alias of the certificate in the keystore used for verification. User property: jarsigner.alias</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>certs</name>
          <description>Show certificate information during verification. User property: jarsigner.certs</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Artifact selection ────────────────────────────────────── -->
        <parameter>
          <name>processMainArtifact</name>
          <description>Whether to verify the main project artifact. User property: jarsigner.processMainArtifact</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.1,)</versionRange>
        </parameter>
        <parameter>
          <name>processAttachedArtifacts</name>
          <description>Whether to verify attached artifacts. User property: jarsigner.processAttachedArtifacts</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.1,)</versionRange>
        </parameter>
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns of artifact filenames to include in verification.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <defaultValue>**/*.jar</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns of artifact filenames to exclude from verification.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>

        <!-- ── Logging ────────────────────────────────────────────────── -->
        <parameter>
          <name>verbose</name>
          <description>Enable verbose output from jarsigner verification. User property: jarsigner.verbose</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the jarsigner:verify goal entirely. User property: jarsigner.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jarsigner:help                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-jarsigner-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[1.2,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.2,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.2,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.2,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.2,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
