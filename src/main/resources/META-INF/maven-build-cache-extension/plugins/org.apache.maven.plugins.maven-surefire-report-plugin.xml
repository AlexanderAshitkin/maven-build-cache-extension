<!--
  Parameter catalog for maven-surefire-report-plugin.
  Source: https://maven.apache.org/plugins/maven-surefire-report-plugin/
  Latest documented version: 3.5.5

  category values:
    functional  - affects the generated test report content
                  (cache must be invalidated on change)
    behavioral  - affects how the report mojo runs but not the output

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-surefire-report-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  surefire-report:report                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>report</name>
      <fullName>org.apache.maven.plugins:maven-surefire-report-plugin:report</fullName>
      <description>Generates an HTML report from Surefire XML test results.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Output location ───────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Output directory for the generated HTML report. Default: ${project.reporting.outputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputName</name>
          <description>Base name for the generated report file (without extension). User property: outputName</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>surefire-report</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Input data ─────────────────────────────────────────────── -->
        <parameter>
          <name>reportsDirectory</name>
          <description>Directory containing Surefire XML result files. Default: ${project.build.directory}/surefire-reports</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/surefire-reports</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>reportsDirectories</name>
          <description>List of directories containing Surefire/Failsafe XML results to aggregate.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.6,)</versionRange>
        </parameter>

        <!-- ── Report content ─────────────────────────────────────────── -->
        <parameter>
          <name>linkXRef</name>
          <description>Link test failures to cross-reference HTML source. User property: linkXRef</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>showSuccess</name>
          <description>Include passing tests in the report (false = failures only). User property: showSuccess</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>aggregate</name>
          <description>Aggregate reports from all modules in a multi-module project. User property: aggregate</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>
        <parameter>
          <name>xrefLocation</name>
          <description>Location of the Xref HTML cross-reference pages for source linking.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}/xref-test</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Skip ───────────────────────────────────────────────────── -->
        <parameter>
          <name>skipSurefireReport</name>
          <description>Skip Surefire report generation entirely. User property: skipSurefireReport</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.11,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
