    <goal>
      <name>unpack</name>
      <fullName>org.apache.maven.plugins:maven-dependency-plugin:unpack</fullName>
      <description>Retrieves a list of artifacts from the repository and unpacks them to a defined location.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Artifact selection ────────────────────────────────────── -->
        <parameter>
          <name>artifact</name>
          <description>Artifact to unpack from command line in groupId:artifactId:version[:packaging[:classifier]] format. User property: artifact</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>artifactItems</name>
          <description>Collection of ArtifactItems to unpack. Each item may specify its own outputDirectory, includes, excludes, and encoding.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Output ────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Default directory into which artifacts are unpacked. User property: outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/dependency</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Content filters ───────────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Comma-separated Ant-style patterns for files to include from the archive. User property: mdep.unpack.includes</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Comma-separated Ant-style patterns for files to exclude from the archive. User property: mdep.unpack.excludes</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Encoding ───────────────────────────────────────────────── -->
        <parameter>
          <name>encoding</name>
          <description>Encoding to use when filtering resources from the archive. User property: encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Overwrite behavior ─────────────────────────────────────── -->
        <parameter>
          <name>overWriteIfNewer</name>
          <description>Overwrite unpacked files if the archive is newer. User property: mdep.overWriteIfNewer</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>overWriteReleases</name>
          <description>Overwrite unpacked release artifacts. User property: mdep.overWriteReleases</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>overWriteSnapshots</name>
          <description>Overwrite unpacked snapshot artifacts. User property: mdep.overWriteSnapshots</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip plugin execution entirely. User property: mdep.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

