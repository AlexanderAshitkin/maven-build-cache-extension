<!--
  Parameter catalog for maven-dependency-plugin.
  Source: https://maven.apache.org/plugins/maven-dependency-plugin/
  Latest documented version: 3.10.0

  category values:
    functional  - affects which artifacts are copied/unpacked or what analysis is performed
    behavioral  - affects how the goal runs (overwrite policies, verbosity) but not the output artifacts

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-dependency-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  dependency:copy                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>copy</name>
      <fullName>org.apache.maven.plugins:maven-dependency-plugin:copy</fullName>
      <description>Copies a list of artifacts from the repository to a defined location.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Artifact selection ────────────────────────────────────── -->
        <parameter>
          <name>artifact</name>
          <description>Artifact to copy from command line in groupId:artifactId:version[:packaging[:classifier]] format. User property: artifact</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>artifactItems</name>
          <description>Collection of ArtifactItems to copy (groupId, artifactId, version, type, classifier, outputDirectory, destFileName).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Output ────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Default directory where artifacts are copied. User property: outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/dependency</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── File naming ───────────────────────────────────────────── -->
        <parameter>
          <name>stripVersion</name>
          <description>Remove the version from the filename of copied artifacts. User property: mdep.stripVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>stripClassifier</name>
          <description>Remove the classifier from the filename of copied artifacts. User property: mdep.stripClassifier</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>prependGroupId</name>
          <description>Prepend the artifact groupId to the filename during copy. User property: mdep.prependGroupId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.7,)</versionRange>
        </parameter>
        <parameter>
          <name>useBaseVersion</name>
          <description>Use artifact baseVersion (not unique SNAPSHOT timestamp) in filename. User property: mdep.useBaseVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.7,)</versionRange>
        </parameter>

        <!-- ── Overwrite behavior ─────────────────────────────────────── -->
        <parameter>
          <name>overWriteIfNewer</name>
          <description>Overwrite artifacts if the source is newer. User property: mdep.overWriteIfNewer</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.7.0,)</versionRange>
        </parameter>
        <parameter>
          <name>overWriteReleases</name>
          <description>Overwrite release artifacts. User property: mdep.overWriteReleases</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>overWriteSnapshots</name>
          <description>Overwrite snapshot artifacts. User property: mdep.overWriteSnapshots</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip plugin execution completely. User property: mdep.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.7,)</versionRange>
        </parameter>

      </parameters>
    </goal>

