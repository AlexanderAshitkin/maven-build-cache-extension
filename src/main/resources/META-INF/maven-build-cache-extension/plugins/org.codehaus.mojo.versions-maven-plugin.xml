<!--
  Parameter catalog for versions-maven-plugin.
  Source: https://www.mojohaus.org/versions/versions-maven-plugin/
  Latest documented version: 2.18.0

  category values:
    functional  - changes the POM files being rewritten or versions being resolved
    behavioral  - affects how the goal runs (logging, backup handling) without
                  changing the resulting POM content

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.codehaus.mojo</groupId>
  <artifactId>versions-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  versions:set                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>set</name>
      <fullName>org.codehaus.mojo:versions-maven-plugin:set</fullName>
      <description>Sets the version of the current project or a specific module in the reactor.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Version coordinates ───────────────────────────────────── -->
        <parameter>
          <name>newVersion</name>
          <description>The new version to set on the matching artifacts. User property: newVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>oldVersion</name>
          <description>The existing version to match (defaults to current project version). User property: oldVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>groupId</name>
          <description>GroupId of the artifact to match (defaults to current project groupId). User property: groupId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>artifactId</name>
          <description>ArtifactId to match (defaults to current project artifactId). User property: artifactId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Scope of changes ───────────────────────────────────────── -->
        <parameter>
          <name>processAllModules</name>
          <description>Update all modules even if they do not reference the old groupId:artifactId. User property: processAllModules</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>updateMatchingVersions</name>
          <description>Update modules whose version matches the old version of the parent. User property: updateMatchingVersions</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>processParent</name>
          <description>Update the parent version declaration as well. User property: processParent</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>processDependencies</name>
          <description>Update dependency version references in the reactor. User property: processDependencies</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>processPlugins</name>
          <description>Update plugin version references in the reactor. User property: processPlugins</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>processProject</name>
          <description>Update the project version itself. User property: processProject</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Backup ─────────────────────────────────────────────────── -->
        <parameter>
          <name>generateBackupPoms</name>
          <description>Create pom.xml.versionsBackup before modifying POMs. User property: generateBackupPoms</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip execution of this goal. User property: versions.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

