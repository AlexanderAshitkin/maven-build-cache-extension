      <fullName>org.codehaus.mojo:versions-maven-plugin:update-parent</fullName>
      <description>Updates the parent version to the latest available in the repository.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>parentVersion</name>
          <description>Force a specific parent version instead of auto-resolving. User property: parentVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>allowSnapshots</name>
          <description>Allow upgrading to SNAPSHOT versions. User property: allowSnapshots</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateBackupPoms</name>
          <description>Create pom.xml.versionsBackup before modifying. User property: generateBackupPoms</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip execution of this goal. User property: versions.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

