        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  versions:display-dependency-updates                                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>display-dependency-updates</name>
      <fullName>org.codehaus.mojo:versions-maven-plugin:display-dependency-updates</fullName>
      <description>Displays all dependencies with newer versions available in the repository.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>rulesUri</name>
          <description>URI of a rules XML file for defining version comparison rules. User property: maven.version.rules</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>ruleSet</name>
          <description>Inline rule set for version comparison controlling ignored and accepted upgrades.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>RuleSet</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.8,)</versionRange>
        </parameter>
        <parameter>
          <name>includes</name>
          <description>Artifact coordinate patterns (groupId:artifactId) to include in the scan.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Artifact coordinate patterns to exclude from the scan.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>allowSnapshots</name>
          <description>Report SNAPSHOT versions as available upgrades. User property: allowSnapshots</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>processDependencyManagement</name>
          <description>Also scan versions declared in dependencyManagement. User property: processDependencyManagement</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip this display goal. User property: versions.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

