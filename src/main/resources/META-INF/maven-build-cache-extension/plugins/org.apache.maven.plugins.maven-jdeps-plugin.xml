<!--
  Parameter catalog for maven-jdeps-plugin.
  Source: https://maven.apache.org/plugins/maven-jdeps-plugin/
  Latest documented version: 3.1.2

  category values:
    functional  - affects the report content or which dependencies are analysed
    behavioral  - affects how the tool runs but not the report content

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-jdeps-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jdeps:jdeps-report                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>jdeps-report</name>
      <fullName>org.apache.maven.plugins:maven-jdeps-plugin:jdeps-report</fullName>
      <description>Generates a jdeps dependency analysis report for main classes.</description>
      <versionRange>[3.0.0,)</versionRange>
      <parameters>

        <!-- ── Output ─────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the jdeps report is written. User property: jdeps.outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>dotOutput</name>
          <description>Directory to write DOT format output files from jdeps. User property: jdeps.dotOutput</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Analysis options ───────────────────────────────────────── -->
        <parameter>
          <name>apiOnly</name>
          <description>Restrict analysis to the public API of classes (jdeps -apionly). User property: jdeps.apiOnly</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>module</name>
          <description>Target module name to analyse (jdeps --module). User property: jdeps.module</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>multiRelease</name>
          <description>Java release version for multi-release JAR analysis (jdeps --multi-release). User property: jdeps.multiRelease</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns for package names to include in the jdeps analysis.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns for package names to exclude from the jdeps analysis.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Toolchain ──────────────────────────────────────────────── -->
        <parameter>
          <name>jdkToolchain</name>
          <description>Toolchain requirements to select the JDK providing the jdeps tool.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>

        <!-- ── Behavioral ─────────────────────────────────────────────── -->
        <parameter>
          <name>verbose</name>
          <description>Print additional verbose output from jdeps. User property: jdeps.verbose</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jdeps:test-jdeps                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>test-jdeps</name>
      <fullName>org.apache.maven.plugins:maven-jdeps-plugin:test-jdeps</fullName>
      <description>Generates a jdeps dependency analysis report for test classes.</description>
      <versionRange>[3.1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the test jdeps report is written.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>dotOutput</name>
          <description>Directory to write DOT format output from test jdeps analysis.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>apiOnly</name>
          <description>Restrict analysis to the public API of test classes.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>module</name>
          <description>Target module name for test jdeps analysis.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>multiRelease</name>
          <description>Java release version for multi-release JAR analysis in test mode.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>jdkToolchain</name>
          <description>Toolchain requirements to select the JDK providing the jdeps tool.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>verbose</name>
          <description>Print additional verbose output from test jdeps. User property: jdeps.verbose</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip test jdeps analysis entirely. User property: jdeps.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jdeps:help                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-jdeps-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[3.0.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. User property: detail</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help. User property: goal</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output formatting. User property: lineLength</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. User property: indentSize</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
