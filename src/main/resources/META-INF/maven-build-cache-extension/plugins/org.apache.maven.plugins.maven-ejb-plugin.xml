<!--
  Parameter catalog for maven-ejb-plugin.
  Source: https://maven.apache.org/plugins/maven-ejb-plugin/
  Latest documented version: 3.2.1

  category values:
    functional  - affects artifact content (which classes end up in the EJB JAR,
                  client JAR content, manifest content, ejb-jar.xml)
    behavioral  - affects how packaging runs but not the output artifact

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-ejb-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  ejb:ejb                                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>ejb</name>
      <fullName>org.apache.maven.plugins:maven-ejb-plugin:ejb</fullName>
      <description>Builds the EJB JAR and optionally the EJB client JAR from project classes.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── EJB version ───────────────────────────────────────────── -->
        <parameter>
          <name>ejbVersion</name>
          <description>EJB specification version to use for the generated ejb-jar.xml (e.g. 3.0, 3.1, 3.2). User property: ejb.ejbVersion. Default: 3.1</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>3.1</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Output ────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the generated EJB JAR is placed. Default: ${project.build.directory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>finalName</name>
          <description>Base name of the generated EJB JAR. Default: ${project.build.finalName}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.finalName}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>classifier</name>
          <description>Classifier appended to the EJB JAR artifact name.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Content inclusion / exclusion ────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns for files to include in the EJB JAR from the classes directory.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns for files to exclude from the EJB JAR.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Client JAR ────────────────────────────────────────────── -->
        <parameter>
          <name>generateClient</name>
          <description>Whether to generate and attach an EJB client JAR. User property: ejb.generateClient. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>clientClassifier</name>
          <description>Classifier for the generated EJB client JAR artifact. Default: client</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>client</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>clientIncludes</name>
          <description>Ant-style patterns for classes to include in the EJB client JAR.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>clientExcludes</name>
          <description>Ant-style patterns for classes to exclude from the EJB client JAR.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>addEjbClientToClasspath</name>
          <description>Whether to add the generated EJB client JAR to the project compile classpath. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.3,)</versionRange>
        </parameter>

        <!-- ── Archive / manifest ────────────────────────────────────── -->
        <parameter>
          <name>archive</name>
          <description>Maven Archiver configuration for the EJB JAR (manifest entries, compression, index).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>MavenArchiveConfiguration</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Deployment descriptor ─────────────────────────────────── -->
        <parameter>
          <name>ejbJar</name>
          <description>Path to a custom ejb-jar.xml to include instead of the generated one.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateEjbJar</name>
          <description>Whether to auto-generate a minimal ejb-jar.xml when none exists. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Reproducible builds ───────────────────────────────────── -->
        <parameter>
          <name>outputTimestamp</name>
          <description>Timestamp for reproducible archive entries (ISO 8601 date-time or seconds since epoch). User property: project.build.outputTimestamp. Default: ${project.build.outputTimestamp}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.outputTimestamp}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the EJB packaging goal. User property: maven.ejb.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.3,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  ejb:help                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-ejb-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. Default: 80</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. Default: 2</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
