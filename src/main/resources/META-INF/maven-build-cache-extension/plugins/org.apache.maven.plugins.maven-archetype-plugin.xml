<!--
  Parameter catalog for maven-archetype-plugin.
  Source: https://maven.apache.org/archetype/maven-archetype-plugin/
  Latest documented version: 3.3.1

  category values:
    functional  - affects generated project structure or archetype JAR content
                  (cache must be invalidated on change)
    behavioral  - affects how the goal runs but not the generated output

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-archetype-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  archetype:generate                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>generate</name>
      <fullName>org.apache.maven.plugins:maven-archetype-plugin:generate</fullName>
      <description>Generates a new Maven project from an archetype.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Archetype selection ───────────────────────────────────── -->
        <parameter>
          <name>archetypeGroupId</name>
          <description>GroupId of the archetype to use. User property: archetypeGroupId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>org.apache.maven.archetypes</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>archetypeArtifactId</name>
          <description>ArtifactId of the archetype to use. User property: archetypeArtifactId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>maven-archetype-quickstart</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>archetypeVersion</name>
          <description>Version of the archetype to use. User property: archetypeVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>archetypeRepository</name>
          <description>Repository URL to search for the archetype. User property: archetypeRepository</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>archetypeCatalog</name>
          <description>Catalog source for browsing archetypes: remote, internal, local, or a URL. User property: archetypeCatalog</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <defaultValue>remote,local</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Generated project coordinates ─────────────────────────── -->
        <parameter>
          <name>groupId</name>
          <description>GroupId for the generated project. User property: groupId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>artifactId</name>
          <description>ArtifactId for the generated project. User property: artifactId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>version</name>
          <description>Version for the generated project. User property: version</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>1.0-SNAPSHOT</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>package</name>
          <description>Base Java package for generated sources. User property: package</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Output location ───────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the generated project is created. User property: outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <defaultValue>${user.dir}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Interaction ───────────────────────────────────────────── -->
        <parameter>
          <name>interactiveMode</name>
          <description>Prompt for missing parameters interactively (false for batch mode). User property: interactiveMode</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Additional properties ─────────────────────────────────── -->
        <parameter>
          <name>archetypePostPhase</name>
          <description>Maven phase to run on the generated project for post-processing validation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  archetype:create-from-project                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>create-from-project</name>
      <fullName>org.apache.maven.plugins:maven-archetype-plugin:create-from-project</fullName>
      <description>Creates an archetype from the current project.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>archetypePostPhase</name>
          <description>Maven phase to run on the generated project for integration testing.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>test</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>defaultEncoding</name>
          <description>Encoding for template files in the generated archetype. User property: archetype.encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>UTF-8</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the archetype project is created. User property: outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.directory}/generated-sources/archetype</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>packageName</name>
          <description>Base package name used as the archetype template variable. User property: packageName</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>ignoreReplica</name>
          <description>Skip creating a replica of the current project alongside the archetype.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>filtereds</name>
          <description>File extensions treated as filtered (text) resources in the archetype.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>preserveCData</name>
          <description>Preserve CDATA sections in XML files during archetype creation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  archetype:crawl                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>crawl</name>
      <fullName>org.apache.maven.plugins:maven-archetype-plugin:crawl</fullName>
      <description>Crawls a repository for archetypes and updates the local catalog.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>catalog</name>
          <description>Path to the archetype catalog file to write. User property: catalog</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${user.home}/.m2/archetype-catalog.xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>repository</name>
          <description>Repository directory to crawl for archetypes. User property: repository</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${user.home}/.m2/repository</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  archetype:integration-test                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>integration-test</name>
      <fullName>org.apache.maven.plugins:maven-archetype-plugin:integration-test</fullName>
      <description>Runs integration tests by generating projects from the archetype and building them.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>archetypePostPhase</name>
          <description>Maven phase to invoke on each generated test project. User property: archetype.test.phase</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>test</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>settingsFile</name>
          <description>Maven settings file to use when building generated test projects.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>testGoals</name>
          <description>Goals to run during integration-test on generated projects. User property: archetype.test.goals</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip archetype integration tests. User property: archetype.test.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  archetype:jar                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>jar</name>
      <fullName>org.apache.maven.plugins:maven-archetype-plugin:jar</fullName>
      <description>Packages the archetype sources into a JAR artifact.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the archetype JAR is written. Default: ${project.build.directory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>finalName</name>
          <description>Base name of the generated archetype JAR (without extension). Default: ${project.build.finalName}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.finalName}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  archetype:help                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-archetype-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. User property: detail</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help. User property: goal</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output formatting. User property: lineLength</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. User property: indentSize</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
