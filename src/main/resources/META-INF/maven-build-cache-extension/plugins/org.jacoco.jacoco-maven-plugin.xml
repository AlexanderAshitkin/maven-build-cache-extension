    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jacoco:check                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>check</name>
      <fullName>org.jacoco:jacoco-maven-plugin:check</fullName>
      <description>Checks that coverage metrics meet the configured threshold rules and optionally fails the build.</description>
      <versionRange>[0.6.3,)</versionRange>
      <parameters>

        <!-- ── Input data ─────────────────────────────────────────────── -->
        <parameter>
          <name>dataFile</name>
          <description>Path to the execution data (.exec) file for coverage analysis. User property: jacoco.dataFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/jacoco.exec</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.3,)</versionRange>
        </parameter>

        <!-- ── Coverage rules ─────────────────────────────────────────── -->
        <parameter>
          <name>rules</name>
          <description>Coverage rule definitions specifying element types, counters, and minimum values.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.3,)</versionRange>
        </parameter>

        <!-- ── Class filtering ────────────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Class name patterns to include when evaluating coverage rules.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.3,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Class name patterns to exclude when evaluating coverage rules.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.3,)</versionRange>
        </parameter>

        <!-- ── Failure behavior ───────────────────────────────────────── -->
        <parameter>
          <name>haltOnFailure</name>
          <description>Fail the build when coverage rules are not met. User property: jacoco.haltOnFailure</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.3,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip coverage check entirely. User property: jacoco.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[0.6.3,)</versionRange>
        </parameter>

      </parameters>
    </goal>

