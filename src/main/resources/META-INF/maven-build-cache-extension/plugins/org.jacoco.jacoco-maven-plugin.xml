          <type>File</type>
          <defaultValue>${project.build.directory}/jacoco-it.exec</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>append</name>
          <description>Append to existing .exec file. User property: jacoco.append</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>includes</name>
          <description>Class name patterns to include in coverage instrumentation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Class name patterns to exclude from coverage instrumentation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>propertyName</name>
          <description>Maven property name that receives the -javaagent JVM argument. User property: jacoco.propertyName</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>argLine</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip JaCoCo integration agent preparation. User property: jacoco.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jacoco:report                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>report</name>
      <fullName>org.jacoco:jacoco-maven-plugin:report</fullName>
      <description>Generates a code coverage report in HTML, XML, and CSV formats.</description>
      <versionRange>[0.5,)</versionRange>
      <parameters>

        <!-- ── Input data ─────────────────────────────────────────────── -->
        <parameter>
          <name>dataFile</name>
          <description>Path to the execution data (.exec) file used to generate the report. User property: jacoco.dataFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/jacoco.exec</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>

        <!-- ── Output ─────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the HTML report is written. User property: jacoco.outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}/jacoco</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>

        <!-- ── Class filtering ────────────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Class name patterns to include in the report.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Class name patterns to exclude from the report.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>

        <!-- ── Report metadata ───────────────────────────────────────── -->
        <parameter>
          <name>title</name>
          <description>Report title shown in the HTML header. User property: jacoco.title</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>
        <parameter>
          <name>footer</name>
          <description>Optional footer text added to each HTML report page. User property: jacoco.footer</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>
        <parameter>
          <name>encoding</name>
          <description>Character encoding for source file rendering in the report. User property: project.build.sourceEncoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>UTF-8</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>

        <!-- ── Format toggles ─────────────────────────────────────────── -->
        <parameter>
          <name>formats</name>
          <description>Report formats to generate: HTML, XML, CSV. User property: jacoco.formats</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.8.7,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip report generation entirely. User property: jacoco.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>

      </parameters>
    </goal>

