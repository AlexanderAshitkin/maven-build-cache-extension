<!--
  Parameter catalog for jacoco-maven-plugin.
  Source: https://www.jacoco.org/jacoco/trunk/doc/maven.html
  Latest documented version: 0.8.12

  category values:
    functional  - affects coverage data files or report content
    behavioral  - affects how the goal runs but not the coverage outputs

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.jacoco</groupId>
  <artifactId>jacoco-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jacoco:prepare-agent                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>prepare-agent</name>
      <fullName>org.jacoco:jacoco-maven-plugin:prepare-agent</fullName>
      <description>Prepares the JaCoCo Java agent for test coverage recording. Sets the argLine property.</description>
      <versionRange>[0.5,)</versionRange>
      <parameters>

        <!-- ── Coverage data output ───────────────────────────────────── -->
        <parameter>
          <name>destFile</name>
          <description>Path to write the execution data (.exec) file. User property: jacoco.destFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/jacoco.exec</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>
        <parameter>
          <name>append</name>
          <description>Append coverage data to existing .exec file rather than overwriting it. User property: jacoco.append</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>

        <!-- ── Class filtering ────────────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Class name patterns (with wildcards) to include in coverage instrumentation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Class name patterns (with wildcards) to exclude from coverage instrumentation.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>
        <parameter>
          <name>exclClassLoaders</name>
          <description>Class loader names whose classes are excluded from instrumentation. User property: jacoco.exclClassLoaders</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>
        <parameter>
          <name>inclBootstrapClasses</name>
          <description>Instrument bootstrap classloader classes (requires special agent options). User property: jacoco.inclBootstrapClasses</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.7.7,)</versionRange>
        </parameter>
        <parameter>
          <name>inclNoLocationClasses</name>
          <description>Instrument classes with no source location attribute. User property: jacoco.inclNoLocationClasses</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.7.7,)</versionRange>
        </parameter>

        <!-- ── Agent configuration ────────────────────────────────────── -->
        <parameter>
          <name>propertyName</name>
          <description>Maven property name that receives the -javaagent JVM argument. User property: jacoco.propertyName</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>argLine</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>
        <parameter>
          <name>sessionId</name>
          <description>Session identifier stored in the execution data (defaults to build timestamp). User property: jacoco.sessionId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>
        <parameter>
          <name>dumpOnExit</name>
          <description>Dump coverage data on JVM exit. User property: jacoco.dumpOnExit</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip JaCoCo agent preparation entirely. User property: jacoco.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[0.5,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jacoco:prepare-agent-integration                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
