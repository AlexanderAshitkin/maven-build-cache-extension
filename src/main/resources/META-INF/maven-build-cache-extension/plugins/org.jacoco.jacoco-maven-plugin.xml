        <parameter>
          <name>destFile</name>
          <description>Path to write the dumped execution data. User property: jacoco.destFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/jacoco.exec</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>address</name>
          <description>Host or IP address of the JaCoCo agent to connect to. User property: jacoco.address</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <defaultValue>localhost</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>port</name>
          <description>TCP port of the JaCoCo agent. User property: jacoco.port</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>6300</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>reset</name>
          <description>Reset coverage data in the agent after dumping. User property: jacoco.reset</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>append</name>
          <description>Append dumped data to an existing .exec file. User property: jacoco.append</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the dump goal entirely. User property: jacoco.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[0.6.4,)</versionRange>
        </parameter>

      </parameters>
    </goal>

