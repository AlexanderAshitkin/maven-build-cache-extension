<!--
  Parameter catalog for maven-artifact-plugin.
  Source: https://maven.apache.org/plugins/maven-artifact-plugin/
  Latest documented version: 3.6.0

  category values:
    functional  - affects buildinfo file content or reproducibility verification
                  (cache must be invalidated on change)
    behavioral  - affects how the goal runs but not the recorded output

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-artifact-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  artifact:buildinfo                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>buildinfo</name>
      <fullName>org.apache.maven.plugins:maven-artifact-plugin:buildinfo</fullName>
      <description>Generates a buildinfo file recording build environment and output checksums.</description>
      <versionRange>[3.2.0,)</versionRange>
      <parameters>

        <!-- ── Output ─────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the buildinfo file is written. Default: ${project.build.directory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>

        <!-- ── Attach ─────────────────────────────────────────────────── -->
        <parameter>
          <name>attach</name>
          <description>Attach the generated buildinfo file as a project artifact. User property: buildinfo.attach</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>

        <!-- ── Reproducibility ────────────────────────────────────────── -->
        <parameter>
          <name>reproducible</name>
          <description>Detect non-reproducible artifacts and emit warnings. User property: buildinfo.reproducible</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.4.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputTimestamp</name>
          <description>Reproducible output timestamp (ISO 8601 or epoch). User property: project.build.outputTimestamp</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.outputTimestamp}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>

        <!-- ── Skip ───────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip buildinfo file generation. User property: buildinfo.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  artifact:check-buildinfo                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>check-buildinfo</name>
      <fullName>org.apache.maven.plugins:maven-artifact-plugin:check-buildinfo</fullName>
      <description>Checks reproducibility by comparing local artifacts against a reference buildinfo.</description>
      <versionRange>[3.2.0,)</versionRange>
      <parameters>

        <!-- ── Reference source ───────────────────────────────────────── -->
        <parameter>
          <name>referenceRepo</name>
          <description>Remote repository URL to download the reference buildinfo from. User property: buildinfo.referenceRepo</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>referenceVersion</name>
          <description>Version of the artifact to use as reference for comparison. User property: buildinfo.referenceVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>referenceBuildinfoFile</name>
          <description>Local buildinfo file to compare against instead of fetching from repository.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>

        <!-- ── Failure handling ───────────────────────────────────────── -->
        <parameter>
          <name>failOnError</name>
          <description>Fail the build if reproducibility check finds mismatches. User property: buildinfo.failOnError</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>

        <!-- ── Skip ───────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip buildinfo check. User property: buildinfo.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  artifact:compare                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>compare</name>
      <fullName>org.apache.maven.plugins:maven-artifact-plugin:compare</fullName>
      <description>Compares locally built artifacts against reference artifacts in a repository.</description>
      <versionRange>[3.3.0,)</versionRange>
      <parameters>

        <!-- ── Reference source ───────────────────────────────────────── -->
        <parameter>
          <name>referenceRepo</name>
          <description>Remote repository URL to download reference artifacts from. User property: buildinfo.referenceRepo</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>referenceVersion</name>
          <description>Reference artifact version to compare against. User property: buildinfo.referenceVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.3.0,)</versionRange>
        </parameter>

        <!-- ── Failure handling ───────────────────────────────────────── -->
        <parameter>
          <name>failOnError</name>
          <description>Fail the build when artifacts do not match. User property: buildinfo.failOnError</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.3.0,)</versionRange>
        </parameter>

        <!-- ── Skip ───────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip artifact comparison. User property: buildinfo.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  artifact:help                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-artifact-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[3.2.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. User property: detail</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help. User property: goal</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output formatting. User property: lineLength</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. User property: indentSize</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.2.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
