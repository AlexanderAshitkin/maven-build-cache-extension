<!--
  Parameter catalog for jdepend-maven-plugin.
  Source: https://www.mojohaus.org/jdepend-maven-plugin/
  Latest documented version: 2.1

  category values:
    functional  - affects which classes are analyzed and where results are written
    behavioral  - affects execution mechanics without changing analysis output

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.codehaus.mojo</groupId>
  <artifactId>jdepend-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jdepend:generate                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>generate</name>
      <fullName>org.codehaus.mojo:jdepend-maven-plugin:generate</fullName>
      <description>Generates a JDepend report analyzing package-level dependencies in compiled classes, forking a new lifecycle.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Input / output locations ──────────────────────────────── -->
        <parameter>
          <name>classDirectory</name>
          <description>Directory containing compiled class files to analyze. User property: classDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the JDepend XML and HTML reports are written. User property: outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputFile</name>
          <description>Name of the generated XML output file. User property: outputFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/jdepend-report.xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip JDepend analysis entirely. User property: jdepend.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jdepend:generate-no-fork                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>generate-no-fork</name>
      <fullName>org.codehaus.mojo:jdepend-maven-plugin:generate-no-fork</fullName>
      <description>Generates a JDepend report without forking a new lifecycle (assumes classes are already compiled).</description>
      <versionRange>[2.1,)</versionRange>
      <parameters>

        <parameter>
          <name>classDirectory</name>
          <description>Directory containing compiled class files to analyze. User property: classDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the JDepend reports are written. User property: outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>
        <parameter>
          <name>outputFile</name>
          <description>Name of the generated XML output file. User property: outputFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/jdepend-report.xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip JDepend analysis entirely. User property: jdepend.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jdepend:help                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.codehaus.mojo:jdepend-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. User property: detail</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help. User property: goal</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. User property: lineLength</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. User property: indentSize</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
