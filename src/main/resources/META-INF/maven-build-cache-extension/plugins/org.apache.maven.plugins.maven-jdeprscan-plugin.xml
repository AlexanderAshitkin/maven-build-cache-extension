<!--
  Parameter catalog for maven-jdeprscan-plugin.
  Source: https://maven.apache.org/plugins/maven-jdeprscan-plugin/
  Latest documented version: 3.0.0
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-jdeprscan-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jdeprscan:jdeprscan                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>jdeprscan</name>
      <fullName>org.apache.maven.plugins:maven-jdeprscan-plugin:jdeprscan</fullName>
      <description>Runs the jdeprscan tool against main compiled classes to detect deprecated API usage.</description>
      <versionRange>[3.0.0,)</versionRange>
      <parameters>

        <!-- ── Analysis target ───────────────────────────────────────── -->
        <parameter>
          <name>classesDirectory</name>
          <description>Directory containing compiled main classes to scan for deprecated API usage.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>release</name>
          <description>Java release version to check against (e.g. 9, 10, 11). User property: jdeprscan.release</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>forRemoval</name>
          <description>Limit scan to deprecated APIs scheduled for removal. User property: jdeprscan.forRemoval</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Toolchain ─────────────────────────────────────────────── -->
        <parameter>
          <name>jdkToolchain</name>
          <description>Toolchain requirements (vendor, version) for selecting the JDK providing jdeprscan.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Logging / failure ─────────────────────────────────────── -->
        <parameter>
          <name>verbose</name>
          <description>Enable verbose output from the jdeprscan tool. User property: jdeprscan.verbose</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>failOnWarning</name>
          <description>Fail the build when deprecated API usage is detected. User property: jdeprscan.failOnWarning</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip jdeprscan execution entirely. User property: jdeprscan.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jdeprscan:test-jdeprscan                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>test-jdeprscan</name>
      <fullName>org.apache.maven.plugins:maven-jdeprscan-plugin:test-jdeprscan</fullName>
      <description>Runs the jdeprscan tool against test compiled classes to detect deprecated API usage.</description>
      <versionRange>[3.0.0,)</versionRange>
      <parameters>

        <!-- ── Analysis target ───────────────────────────────────────── -->
        <parameter>
          <name>testClassesDirectory</name>
          <description>Directory containing compiled test classes to scan for deprecated API usage.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.testOutputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>release</name>
          <description>Java release version to check against (e.g. 9, 10, 11). User property: jdeprscan.release</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>forRemoval</name>
          <description>Limit scan to deprecated APIs scheduled for removal. User property: jdeprscan.forRemoval</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Toolchain ─────────────────────────────────────────────── -->
        <parameter>
          <name>jdkToolchain</name>
          <description>Toolchain requirements (vendor, version) for selecting the JDK providing jdeprscan.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Logging / failure ─────────────────────────────────────── -->
        <parameter>
          <name>verbose</name>
          <description>Enable verbose output from the jdeprscan tool. User property: jdeprscan.verbose</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>failOnWarning</name>
          <description>Fail the build when deprecated API usage is detected. User property: jdeprscan.failOnWarning</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip test-jdeprscan execution entirely. User property: jdeprscan.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jdeprscan:help                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-jdeprscan-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[3.0.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
