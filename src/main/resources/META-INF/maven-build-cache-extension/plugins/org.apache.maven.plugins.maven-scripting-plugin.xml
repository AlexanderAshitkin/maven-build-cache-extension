<!--
  Parameter catalog for maven-scripting-plugin.
  Source: https://maven.apache.org/plugins/maven-scripting-plugin/
  Latest documented version: 3.0.0

  category values:
    functional  - affects the script executed and its outputs
    behavioral  - affects how the goal runs but not the script or its outputs

  envSpecific: true if the parameter commonly carries file-system paths,
               free-form script content, or machine-specific values.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-scripting-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  scripting:eval                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>eval</name>
      <fullName>org.apache.maven.plugins:maven-scripting-plugin:eval</fullName>
      <description>Evaluates an inline or file-based script using a JSR-223 scripting engine.</description>
      <versionRange>[3.0.0,)</versionRange>
      <parameters>

        <!-- ── Script content ─────────────────────────────────────────── -->
        <parameter>
          <name>script</name>
          <description>Inline script source to evaluate, or path to a script file (may contain file paths).</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Engine selection ───────────────────────────────────────── -->
        <parameter>
          <name>engineName</name>
          <description>Name of the JSR-223 scripting engine to use (e.g. groovy, javascript, jython).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Lifecycle binding ──────────────────────────────────────── -->
        <parameter>
          <name>phase</name>
          <description>Lifecycle phase at which this script evaluation is bound.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip script evaluation entirely. User property: maven.scripting.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  scripting:help                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-scripting-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[3.0.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
