<!--
  Parameter catalog for maven-jxr-plugin.
  Source: https://maven.apache.org/plugins/maven-jxr-plugin/
  Latest documented version: 3.6.0

  category values:
    functional  - affects the content or structure of the generated cross-reference
    behavioral  - affects how the goal runs but not the cross-reference content

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-jxr-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  jxr:jxr                                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>jxr</name>
      <fullName>org.apache.maven.plugins:maven-jxr-plugin:jxr</fullName>
      <description>Generates an HTML cross-reference of the project main sources.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Output directory ───────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the JXR cross-reference HTML is written. User property: outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <defaultValue>${project.reporting.outputDirectory}/xref</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Encoding ───────────────────────────────────────────────── -->
        <parameter>
          <name>inputEncoding</name>
          <description>Encoding of the source files to be cross-referenced. User property: inputEncoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.sourceEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputEncoding</name>
          <description>Encoding of the generated cross-reference HTML pages. User property: outputEncoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.reporting.outputEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Stylesheet ─────────────────────────────────────────────── -->
        <parameter>
          <name>stylesheet</name>
          <description>Path to a custom CSS stylesheet file for the cross-reference pages. User property: stylesheet</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── File filtering ─────────────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns for source files to include in the cross-reference. User property: includes</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>ArrayList</type>
          <defaultValue>**/*.java</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns for source files to exclude from the cross-reference. User property: excludes</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>ArrayList</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Javadoc linking ────────────────────────────────────────── -->
        <parameter>
          <name>linkJavadoc</name>
          <description>Add links to Javadoc from cross-referenced source lines. User property: linkJavadoc</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>javadocDir</name>
          <description>Location of generated Javadoc output for Javadoc cross-linking. User property: javadocDir</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}/apidocs</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Page titles ────────────────────────────────────────────── -->
        <parameter>
          <name>docTitle</name>
          <description>Title shown on the cross-reference overview page. User property: docTitle</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.name} ${project.version} Reference</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>windowTitle</name>
          <description>Browser window title for the cross-reference pages. User property: windowTitle</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.name} ${project.version} Reference</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>bottom</name>
          <description>Footer HTML text placed at the bottom of each cross-reference page. User property: bottom</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip JXR cross-reference generation entirely. User property: maven.jxr.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>

      </parameters>
    </goal>

