<!--
  Parameter catalog for findbugs-maven-plugin.
  Source: https://gleclaire.github.io/findbugs-maven-plugin/
  Latest documented version: 3.0.5
  NOTE: FindBugs is superseded by SpotBugs; this catalog covers the legacy plugin.
-->
<plugin-catalog>
  <groupId>org.codehaus.mojo</groupId>
  <artifactId>findbugs-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  findbugs:findbugs                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>findbugs</name>
      <fullName>org.codehaus.mojo:findbugs-maven-plugin:findbugs</fullName>
      <description>Analyzes class files and produces a FindBugs report.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>classFilesDirectory</name>
          <description>Location of class files to analyze. Default: ${project.build.outputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>testClassFilesDirectory</name>
          <description>Location of test class files to analyze. Default: ${project.build.testOutputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.testOutputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where FindBugs reports are written. Default: ${project.build.directory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>effort</name>
          <description>Analysis effort level: Min, Default, or Max. User property: findbugs.effort</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>Default</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>threshold</name>
          <description>Minimum bug priority to report: High, Default (Medium), Low, Ignore, Exp. User property: findbugs.threshold</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>Default</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>includeFilterFile</name>
          <description>Filter file to include only specified bugs. User property: findbugs.includeFilterFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludeFilterFile</name>
          <description>Filter file to exclude specified bugs. User property: findbugs.excludeFilterFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>pluginList</name>
          <description>Comma-separated list of FindBugs plugin JARs. User property: findbugs.pluginList</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>includeTests</name>
          <description>Analyze test class files as well as main classes. User property: findbugs.includeTests</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>visitors</name>
          <description>Comma-separated list of bug detectors to run. User property: findbugs.visitors</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>omitVisitors</name>
          <description>Comma-separated list of bug detectors to skip. User property: findbugs.omitVisitors</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>maxRank</name>
          <description>Maximum bug rank to report (1=scariest, 20=least scary). User property: findbugs.maxRank</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip FindBugs analysis entirely. User property: findbugs.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>debug</name>
          <description>Enable FindBugs debug output. User property: findbugs.debug</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  findbugs:check                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>check</name>
      <fullName>org.codehaus.mojo:findbugs-maven-plugin:check</fullName>
      <description>Runs FindBugs analysis and fails the build if bugs are found.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>effort</name>
          <description>Analysis effort level: Min, Default, or Max. User property: findbugs.effort</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>Default</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>threshold</name>
          <description>Minimum bug priority to report. User property: findbugs.threshold</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>Default</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>maxAllowedViolations</name>
          <description>Maximum number of violations allowed before failing. User property: findbugs.maxAllowedViolations</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>0</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>
        <parameter>
          <name>includeFilterFile</name>
          <description>Filter file to include only specified bugs. User property: findbugs.includeFilterFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludeFilterFile</name>
          <description>Filter file to exclude specified bugs. User property: findbugs.excludeFilterFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>failOnError</name>
          <description>Fail build when FindBugs encounters an analysis error. User property: findbugs.failOnError</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip FindBugs check entirely. User property: findbugs.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  findbugs:help                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.codehaus.mojo:findbugs-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. Default: 80</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. Default: 2</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
