    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  javadoc:jar                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>jar</name>
      <fullName>org.apache.maven.plugins:maven-javadoc-plugin:jar</fullName>
      <description>Bundles the generated Javadoc into a JAR artifact.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

