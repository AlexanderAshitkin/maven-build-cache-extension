          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>
        <parameter>
          <name>failOnWarnings</name>
          <description>Fail the build if javadoc tool reports warnings. User property: maven.javadoc.failOnWarnings</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.1,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip Javadoc generation entirely. User property: maven.javadoc.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>

      </parameters>
    </goal>

