<!--
  Parameter catalog for maven-javadoc-plugin.
  Source: https://maven.apache.org/plugins/maven-javadoc-plugin/
  Latest documented version: 3.11.2

  category values:
    functional  - affects the content or structure of the generated Javadoc
    behavioral  - affects how the goal runs but not the Javadoc content

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-javadoc-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  javadoc:javadoc                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>javadoc</name>
      <fullName>org.apache.maven.plugins:maven-javadoc-plugin:javadoc</fullName>
      <description>Generates Javadoc HTML pages for the project main sources.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Output directories ─────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Destination directory for generated Javadoc files. User property: destDir</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/apidocs</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>reportOutputDirectory</name>
          <description>Report output directory for site integration. User property: reportOutputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}/apidocs</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Source ─────────────────────────────────────────────────── -->
        <parameter>
          <name>sourcepath</name>
          <description>Colon-separated list of paths to source files for Javadoc. User property: sourcepath</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>subpackages</name>
          <description>Colon-separated package names to recursively include. User property: subpackages</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludePackageNames</name>
          <description>Colon-separated list of package patterns to exclude. User property: excludePackageNames</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>source</name>
          <description>Java language version passed to javadoc tool (-source). User property: source</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>release</name>
          <description>Java release version for javadoc tool (--release). User property: release</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Encoding ───────────────────────────────────────────────── -->
        <parameter>
          <name>encoding</name>
          <description>Encoding of source files (-encoding). User property: encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.sourceEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>docencoding</name>
          <description>Encoding of generated HTML output (-docencoding). User property: docencoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>UTF-8</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>charset</name>
          <description>HTML charset meta tag value (-charset). User property: charset</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>UTF-8</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── HTML content ───────────────────────────────────────────── -->
        <parameter>
          <name>author</name>
          <description>Include @author tag in generated docs. User property: author</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>version</name>
          <description>Include @version tag in generated docs. User property: version</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>bottom</name>
          <description>HTML text placed at the bottom of each output page. User property: bottom</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>header</name>
          <description>HTML text placed at the top of each output page. User property: header</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>footer</name>
          <description>HTML text placed at the bottom of each output page. User property: footer</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>top</name>
          <description>HTML text placed above the navigation bar on each page. User property: top</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.5,)</versionRange>
        </parameter>
        <parameter>
          <name>windowtitle</name>
          <description>Browser window title for the generated documentation. User property: windowtitle</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.name} ${project.version} API</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>doctitle</name>
          <description>Title for the overview summary page. User property: doctitle</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.name} ${project.version} API</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>overview</name>
          <description>Path to an HTML overview page to include. User property: overview</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Visibility scope ───────────────────────────────────────── -->
        <parameter>
          <name>show</name>
          <description>Scope of members to document: public, protected, package, or private. User property: show</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>protected</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Tags and taglets ───────────────────────────────────────── -->
        <parameter>
          <name>tags</name>
          <description>Custom tag definitions (-tag name:placement:header) to register.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>
        <parameter>
          <name>taglet</name>
          <description>Fully qualified class name of a custom Taglet to use. User property: taglet</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>
        <parameter>
          <name>tagletpath</name>
          <description>Search paths for taglet classes. User property: tagletpath</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>
        <parameter>
          <name>tagletArtifacts</name>
          <description>Maven artifact coordinates for taglet JARs to add to taglet classpath.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>

        <!-- ── Links ──────────────────────────────────────────────────── -->
        <parameter>
          <name>links</name>
          <description>List of URLs for external Javadoc packages to cross-reference. User property: links</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>ArrayList</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>offlineLinks</name>
          <description>List of offline package-list locations for external Javadoc cross-references.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>OfflineLink[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>detectLinks</name>
          <description>Auto-detect Javadoc links from project dependencies. User property: detectLinks</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>detectJavaApiLink</name>
          <description>Auto-detect and link to the JDK API docs for the project source version. User property: detectJavaApiLink</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.6,)</versionRange>
        </parameter>
        <parameter>
          <name>linksource</name>
          <description>Create HTML hyperlinks to source code for each class/interface/method. User property: linksource</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Frame / navigation options ────────────────────────────── -->
        <parameter>
          <name>splitindex</name>
          <description>Split the index into separate per-letter files. User property: splitindex</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>use</name>
          <description>Include a Class Use page for each class/interface. User property: use</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>noindex</name>
          <description>Omit the index from the generated docs. User property: noindex</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>notree</name>
          <description>Omit the class hierarchy tree from the generated docs. User property: notree</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>nohelp</name>
          <description>Omit the help link from the navigation bar. User property: nohelp</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>nonavbar</name>
          <description>Omit the navigation bar from all pages. User property: nonavbar</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>nodeprecated</name>
          <description>Omit deprecated API information from generated docs. User property: nodeprecated</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>nodeprecatedlist</name>
          <description>Omit the deprecated API list page from generated docs. User property: nodeprecatedlist</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>nocomment</name>
          <description>Suppress all comments and descriptive text from generated docs. User property: nocomment</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Stylesheet ─────────────────────────────────────────────── -->
        <parameter>
          <name>stylesheet</name>
          <description>Built-in stylesheet selection: maven or java. User property: stylesheet</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>java</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>stylesheetfile</name>
          <description>Path to a custom CSS stylesheet to use in the generated Javadoc. User property: stylesheetfile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>addStylesheets</name>
          <description>Additional CSS stylesheets to include. User property: addStylesheets</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.3.0,)</versionRange>
        </parameter>

        <!-- ── Doclint ────────────────────────────────────────────────── -->
        <parameter>
          <name>doclint</name>
          <description>Doclint checks to enable/disable (e.g., none, all, -missing). User property: doclint</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.10.0,)</versionRange>
        </parameter>

        <!-- ── Misc Javadoc options ───────────────────────────────────── -->
        <parameter>
          <name>breakiterator</name>
          <description>Use BreakIterator for sentence boundary detection in summaries. User property: breakiterator</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>docfilessubdirs</name>
          <description>Recursively copy doc-files subdirectories. User property: docfilessubdirs</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>locale</name>
          <description>Locale used for generated documentation text. User property: locale</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>serialwarn</name>
          <description>Generate warnings about missing @serial tags. User property: serialwarn</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>sourcetab</name>
          <description>Number of spaces for tab expansion in source views. User property: sourcetab</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>4</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>
        <parameter>
          <name>groups</name>
          <description>List of package groups to display in the overview summary. User property: groups</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>additionalJOptions</name>
          <description>Additional JVM options passed to the javadoc tool. User property: additionalJOptions</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.9,)</versionRange>
        </parameter>
        <parameter>
          <name>additionalOptions</name>
          <description>Additional options passed directly to the javadoc command line. User property: additionalOptions</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

