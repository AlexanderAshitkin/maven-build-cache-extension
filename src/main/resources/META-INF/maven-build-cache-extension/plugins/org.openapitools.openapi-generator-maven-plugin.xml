<!--
  Parameter catalog for openapi-generator-maven-plugin.
  Source: https://github.com/OpenAPITools/openapi-generator/tree/master/modules/openapi-generator-maven-plugin
  Latest documented version: 7.10.0
-->
<plugin-catalog>
  <groupId>org.openapitools</groupId>
  <artifactId>openapi-generator-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  openapi-generator:generate                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>generate</name>
      <fullName>org.openapitools:openapi-generator-maven-plugin:generate</fullName>
      <description>Generates client/server code from an OpenAPI specification.</description>
      <versionRange>[3.0,)</versionRange>
      <parameters>

        <parameter>
          <name>inputSpec</name>
          <description>Path or URL to the OpenAPI specification file. User property: openapi.generator.maven.plugin.inputSpec</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generatorName</name>
          <description>Generator to use (e.g. java, spring, python). User property: openapi.generator.maven.plugin.generatorName</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>output</name>
          <description>Directory where generated code is written. Default: ${project.build.directory}/generated-sources/openapi</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/generated-sources/openapi</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>apiPackage</name>
          <description>Package name for generated API classes. User property: openapi.generator.maven.plugin.apiPackage</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>modelPackage</name>
          <description>Package name for generated model classes. User property: openapi.generator.maven.plugin.modelPackage</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>invokerPackage</name>
          <description>Package name for generated invoker/support classes. User property: openapi.generator.maven.plugin.invokerPackage</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>configOptions</name>
          <description>Generator-specific configuration options (key-value map).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>templateDirectory</name>
          <description>Directory containing custom Mustache templates. User property: openapi.generator.maven.plugin.templateDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>library</name>
          <description>Generator library variant (e.g. resttemplate, webclient for java generator).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateApis</name>
          <description>Generate API source files. Default: true. User property: openapi.generator.maven.plugin.generateApis</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateModels</name>
          <description>Generate model source files. Default: true. User property: openapi.generator.maven.plugin.generateModels</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateSupportingFiles</name>
          <description>Generate supporting files (build files, README, etc.). Default: true</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateApiTests</name>
          <description>Generate API test stubs. Default: true. User property: openapi.generator.maven.plugin.generateApiTests</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateModelTests</name>
          <description>Generate model test stubs. Default: true. User property: openapi.generator.maven.plugin.generateModelTests</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>apisToGenerate</name>
          <description>Comma-separated list of API tags to generate (empty = all).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[4.0,)</versionRange>
        </parameter>
        <parameter>
          <name>modelsToGenerate</name>
          <description>Comma-separated list of model names to generate (empty = all).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[4.0,)</versionRange>
        </parameter>
        <parameter>
          <name>importMappings</name>
          <description>Map from type name to fully-qualified import for generated code.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>typeMappings</name>
          <description>Map from OAS type to Java type for generated code.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>addCompileSourceRoot</name>
          <description>Add generated sources to the compile source root. Default: true</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip code generation entirely. User property: openapi.generator.maven.plugin.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  openapi-generator:validate                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>validate</name>
      <fullName>org.openapitools:openapi-generator-maven-plugin:validate</fullName>
      <description>Validates an OpenAPI specification for correctness.</description>
      <versionRange>[3.0,)</versionRange>
      <parameters>

        <parameter>
          <name>inputSpec</name>
          <description>Path or URL to the OpenAPI specification file to validate.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip validation. User property: openapi.generator.maven.plugin.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  openapi-generator:help                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.openapitools:openapi-generator-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[3.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. Default: 80</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. Default: 2</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
