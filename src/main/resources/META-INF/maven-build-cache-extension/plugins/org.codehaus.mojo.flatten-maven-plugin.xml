<!--
  Parameter catalog for flatten-maven-plugin.
  Source: https://www.mojohaus.org/flatten-maven-plugin/
  Latest documented version: 1.7.0

  category values:
    functional  - affects the content or location of the flattened POM file
    behavioral  - affects execution mechanics without changing the flattened POM

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.codehaus.mojo</groupId>
  <artifactId>flatten-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  flatten:flatten                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>flatten</name>
      <fullName>org.codehaus.mojo:flatten-maven-plugin:flatten</fullName>
      <description>Generates a flattened version of the POM with resolved expressions and removed build-time elements.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Flattening mode ────────────────────────────────────────── -->
        <parameter>
          <name>flattenMode</name>
          <description>Predefined flattening preset controlling which POM sections are kept or resolved: ossrh, bom, oss, defaults, clean, fatjar, resolveCiFriendliesOnly. User property: flatten.mode</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>ossrh</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>flattenDependencyMode</name>
          <description>How transitive dependencies are handled in the flattened POM: direct, all. User property: flatten.dependencyMode</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.1,)</versionRange>
        </parameter>

        <!-- ── Fine-grained POM element control ──────────────────────── -->
        <parameter>
          <name>pomElements</name>
          <description>Fine-grained descriptor controlling which individual POM elements are kept, removed, or resolved in the flattened output.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>FlattenDescriptor</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Output location ────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the flattened POM file is written. User property: flatten.outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>flattenedPomFilename</name>
          <description>Name of the generated flattened POM file. User property: flattenedPomFilename</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>.flattened-pom.xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── POM installation / deployment ─────────────────────────── -->
        <parameter>
          <name>updatePomFile</name>
          <description>Replace the project POM file with the flattened version for install and deploy. User property: updatePomFile</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Build profile dependencies ────────────────────────────── -->
        <parameter>
          <name>embedBuildProfileDependencies</name>
          <description>Include dependencies declared inside build profiles in the flattened POM. User property: embedBuildProfileDependencies</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.1,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the flatten goal entirely. User property: flatten.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  flatten:clean                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>clean</name>
      <fullName>org.codehaus.mojo:flatten-maven-plugin:clean</fullName>
      <description>Deletes the flattened POM file generated by flatten:flatten.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>outputDirectory</name>
          <description>Directory containing the flattened POM file to delete. User property: flatten.outputDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>flattenedPomFilename</name>
          <description>Name of the flattened POM file to delete. User property: flattenedPomFilename</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>.flattened-pom.xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the clean goal. User property: flatten.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  flatten:help                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.codehaus.mojo:flatten-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
