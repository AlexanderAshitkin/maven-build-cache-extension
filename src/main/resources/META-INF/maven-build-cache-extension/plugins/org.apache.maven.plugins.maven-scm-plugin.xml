  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  scm:checkout                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>checkout</name>
      <fullName>org.apache.maven.plugins:maven-scm-plugin:checkout</fullName>
      <description>Checks out a project from SCM into a local directory.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>checkoutDirectory</name>
          <description>Local directory where the SCM checkout is placed. User property: checkoutDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/checkout</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>connectionType</name>
          <description>SCM connection type to use: connection or developerConnection. User property: connectionType</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>connection</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>scmVersion</name>
          <description>Specific branch, tag, or revision to check out. User property: scmVersion</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>scmVersionType</name>
          <description>Type of scmVersion: branch, tag, or revision. User property: scmVersionType</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>branch</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>shallow</name>
          <description>Create a shallow checkout (history-truncated) where supported by the SCM provider.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.5,)</versionRange>
        </parameter>
        <parameter>
          <name>useExport</name>
          <description>Use SCM export (no working copy metadata) instead of checkout. User property: useExport</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip SCM checkout entirely. User property: maven.scm.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

