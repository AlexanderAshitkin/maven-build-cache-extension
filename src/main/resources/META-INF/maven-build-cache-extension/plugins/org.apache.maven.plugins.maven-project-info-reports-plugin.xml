<!--
  Parameter catalog for maven-project-info-reports-plugin.
  Source: https://maven.apache.org/plugins/maven-project-info-reports-plugin/
  Latest documented version: 3.9.0

  category values:
    functional  - affects report content (cache must be invalidated on change)
    behavioral  - affects how the report mojo runs but not the output content

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-project-info-reports-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  project-info-reports:dependencies                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>dependencies</name>
      <fullName>org.apache.maven.plugins:maven-project-info-reports-plugin:dependencies</fullName>
      <description>Generates a report of the project dependency tree.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>outputDirectory</name>
          <description>Output directory for the report. Default: ${project.reporting.outputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputEncoding</name>
          <description>Encoding of the generated report. Default: ${project.reporting.outputEncoding}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.reporting.outputEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>dependencyDetailsEnabled</name>
          <description>Include detailed dependency information (jar size, sealed, etc.) in report.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>dependencyLocationsEnabled</name>
          <description>Include repository location information for dependencies in report.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

