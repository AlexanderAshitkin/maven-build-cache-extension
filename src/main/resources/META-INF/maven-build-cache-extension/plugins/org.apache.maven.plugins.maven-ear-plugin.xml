<!--
  Parameter catalog for maven-ear-plugin.
  Source: https://maven.apache.org/plugins/maven-ear-plugin/
  Latest documented version: 3.3.0

  category values:
    functional  - affects artifact content (which modules end up in the EAR,
                  application.xml content, archive structure, descriptor content)
    behavioral  - affects how packaging runs but not the output artifact

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-ear-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  ear:ear                                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>ear</name>
      <fullName>org.apache.maven.plugins:maven-ear-plugin:ear</fullName>
      <description>Builds the EAR archive from project modules and resources.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Source directory ───────────────────────────────────────── -->
        <parameter>
          <name>earSourceDirectory</name>
          <description>Directory containing EAR source files (resources, descriptors, etc.). Default: ${basedir}/src/main/application</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${basedir}/src/main/application</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>earSourceIncludes</name>
          <description>Comma-separated Ant-style patterns for files to include from earSourceDirectory. Default: **</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>**</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>earSourceExcludes</name>
          <description>Comma-separated Ant-style patterns for files to exclude from earSourceDirectory.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Output ────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the generated EAR file is placed. Default: ${project.build.directory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>finalName</name>
          <description>Base name of the generated EAR file. Default: ${project.build.finalName}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.finalName}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>classifier</name>
          <description>Classifier appended to the EAR artifact name.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Application descriptor ────────────────────────────────── -->
        <parameter>
          <name>applicationXml</name>
          <description>Path to an existing application.xml descriptor to use instead of the generated one.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateApplicationXml</name>
          <description>Whether to generate the application.xml deployment descriptor. Default: true</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>applicationName</name>
          <description>The application-name element value written to application.xml (Java EE 6+).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.9,)</versionRange>
        </parameter>
        <parameter>
          <name>description</name>
          <description>Content of the description element in the generated application.xml.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>displayName</name>
          <description>Content of the display-name element in the generated application.xml.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Modules ───────────────────────────────────────────────── -->
        <parameter>
          <name>modules</name>
          <description>List of EAR module configurations controlling how each dependency is packaged and described in application.xml.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>EarModule[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>defaultLibBundleDir</name>
          <description>Default bundle directory inside the EAR for library JARs. User property: ear.defaultLibBundleDir</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>includeLibInApplicationXml</name>
          <description>Whether lib JARs bundled in the EAR should be listed as library-directory in application.xml. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateModuleId</name>
          <description>Auto-generate the id attribute for each module element in application.xml. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Archive / packaging ───────────────────────────────────── -->
        <parameter>
          <name>archive</name>
          <description>Maven Archiver configuration for the EAR archive (manifest, index, compression).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>MavenArchiveConfiguration</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>unpackTypes</name>
          <description>Comma-separated list of dependency types to unpack into the EAR rather than bundling as archives.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>fileNameMapping</name>
          <description>File name mapping strategy for bundled modules (no-version, no-version-for-default-mapping, full, or custom expression).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skinnyWars</name>
          <description>When true, WARs are packaged without their own WEB-INF/lib, relying on the EAR's lib instead. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.7,)</versionRange>
        </parameter>
        <parameter>
          <name>skinnySkipOptionalDeps</name>
          <description>When skinnyWars=true, also skip optional WAR dependencies from being promoted to the EAR lib. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

        <!-- ── Java EE / Jakarta EE version ─────────────────────────── -->
        <parameter>
          <name>version</name>
          <description>Java EE / Jakarta EE version for the generated application.xml (e.g. 1.4, 5, 6, 7, 8, 9, 10). User property: ear.version</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Filtering ─────────────────────────────────────────────── -->
        <parameter>
          <name>filtering</name>
          <description>Whether to enable Maven resource filtering for EAR source files. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>filters</name>
          <description>List of property files supplying values for resource filtering.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Reproducible builds ───────────────────────────────────── -->
        <parameter>
          <name>outputTimestamp</name>
          <description>Timestamp for reproducible archive entries (ISO 8601 date-time or seconds since epoch). User property: project.build.outputTimestamp. Default: ${project.build.outputTimestamp}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.outputTimestamp}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the EAR packaging. User property: maven.ear.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  ear:generate-application-xml                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>generate-application-xml</name>
      <fullName>org.apache.maven.plugins:maven-ear-plugin:generate-application-xml</fullName>
      <description>Generates the application.xml deployment descriptor (and jboss-app.xml if configured) without building the EAR.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>generatedDescriptorLocation</name>
          <description>Directory where the generated application.xml is written. Default: ${project.build.directory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>version</name>
          <description>Java EE / Jakarta EE spec version for the generated application.xml. User property: ear.version</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>modules</name>
          <description>List of EAR module configurations described in the application.xml.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>EarModule[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generateApplicationXml</name>
          <description>Whether to generate the application.xml descriptor. Default: true</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>includeLibInApplicationXml</name>
          <description>Whether lib JARs should be listed in application.xml as library-directory. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>defaultLibBundleDir</name>
          <description>Default bundle directory for library JARs within the EAR.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip generating the application.xml. User property: maven.ear.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  ear:help                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-ear-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. Default: 80</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. Default: 2</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
