<!--
  Parameter catalog for buildnumber-maven-plugin.
  Source: https://www.mojohaus.org/buildnumber-maven-plugin/
  Latest documented version: 3.2.0
-->
<plugin-catalog>
  <groupId>org.codehaus.mojo</groupId>
  <artifactId>buildnumber-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  buildnumber:create                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>create</name>
      <fullName>org.codehaus.mojo:buildnumber-maven-plugin:create</fullName>
      <description>Creates a build number from SCM revision or a custom format.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <parameter>
          <name>buildNumberPropertyName</name>
          <description>Name of the property to set with the build number. Default: buildNumber</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>buildNumber</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>format</name>
          <description>Format string for the build number (java.text.MessageFormat). Used when items is set.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>items</name>
          <description>Items to include in the build number format string (scmVersion, timestamp, etc.).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>shortRevisionLength</name>
          <description>Number of characters to use from the SCM revision. 0 means full revision.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>0</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>timestampFormat</name>
          <description>Format for timestamp when used in format string (java.text.SimpleDateFormat).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>timestampPropertyName</name>
          <description>Name of the property to set with the build timestamp.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>timestamp</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>scmBranchPropertyName</name>
          <description>Name of the property to set with the SCM branch name.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>scmBranch</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>
        <parameter>
          <name>connectionType</name>
          <description>SCM connection type to use: connection or developerConnection.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>connection</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>doCheck</name>
          <description>Check for local modifications before building; fail if modifications found.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>doUpdate</name>
          <description>Update the local workspace from SCM before building.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>getRevisionOnlyOnce</name>
          <description>Retrieve SCM revision only once per build, sharing across all modules.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>useLastCommittedRevision</name>
          <description>Use the last committed revision rather than the working copy revision.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>revisionOnScmFailure</name>
          <description>Fallback value if SCM revision retrieval fails; instead of failing the build.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>addOutputDirectoryToResources</name>
          <description>Add the generated properties file output directory as a resource directory.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip execution of the create goal. User property: maven.buildNumber.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  buildnumber:create-timestamp                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>create-timestamp</name>
      <fullName>org.codehaus.mojo:buildnumber-maven-plugin:create-timestamp</fullName>
      <description>Creates a build timestamp property without SCM interaction.</description>
      <versionRange>[1.4,)</versionRange>
      <parameters>

        <parameter>
          <name>timestampFormat</name>
          <description>Format for the timestamp (java.text.SimpleDateFormat pattern).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.4,)</versionRange>
        </parameter>
        <parameter>
          <name>timestampPropertyName</name>
          <description>Name of the property to set with the formatted timestamp.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>timestamp</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.4,)</versionRange>
        </parameter>
        <parameter>
          <name>timezone</name>
          <description>Timezone for the timestamp (e.g. UTC, America/New_York).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.4,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  buildnumber:create-metadata                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>create-metadata</name>
      <fullName>org.codehaus.mojo:buildnumber-maven-plugin:create-metadata</fullName>
      <description>Writes build metadata to a properties file from project properties.</description>
      <versionRange>[3.0,)</versionRange>
      <parameters>

        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the metadata properties file is written.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputName</name>
          <description>File name for the metadata properties file.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>build.properties</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>properties</name>
          <description>Property names to include in the metadata file.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>addOutputDirectoryToResources</name>
          <description>Register the output directory as a project resource.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  buildnumber:help                                                   -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.codehaus.mojo:buildnumber-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. Default: 80</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. Default: 2</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
