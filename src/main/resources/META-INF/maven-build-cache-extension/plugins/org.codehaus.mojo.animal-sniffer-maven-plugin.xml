<!--
  Parameter catalog for animal-sniffer-maven-plugin.
  Source: https://www.mojohaus.org/animal-sniffer/animal-sniffer-maven-plugin/
  Latest documented version: 1.24

  category values:
    functional  - affects which classes/signatures are checked or generated
    behavioral  - affects how the goal runs without changing verification results

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.codehaus.mojo</groupId>
  <artifactId>animal-sniffer-maven-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  animal-sniffer:check                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>check</name>
      <fullName>org.codehaus.mojo:animal-sniffer-maven-plugin:check</fullName>
      <description>Checks class files against an API signature to detect use of non-portable APIs.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Signature to check against ────────────────────────────── -->
        <parameter>
          <name>signature</name>
          <description>Artifact (groupId:artifactId:version) of the API signature to check against.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Signature</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Annotation-based ignores ───────────────────────────────── -->
        <parameter>
          <name>annotations</name>
          <description>Annotation class names that mark methods/classes to ignore during signature checking.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.2,)</versionRange>
        </parameter>

        <!-- ── Pattern-based ignores ──────────────────────────────────── -->
        <parameter>
          <name>ignores</name>
          <description>List of dotted class/package name patterns to exclude from signature checking.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Dependency-based ignores ───────────────────────────────── -->
        <parameter>
          <name>ignoreDependencies</name>
          <description>Whether to ignore signatures provided by the project's direct dependencies.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.6,)</versionRange>
        </parameter>

        <!-- ── Test classes ───────────────────────────────────────────── -->
        <parameter>
          <name>checkTestClasses</name>
          <description>Whether to also check test classes (testClassesDirectory) against the signature.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>

        <!-- ── Source directories ─────────────────────────────────────── -->
        <parameter>
          <name>sourceDirectory</name>
          <description>Directory containing main Java sources (used to resolve line numbers in reports).</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.sourceDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>testSourceDirectory</name>
          <description>Directory containing test Java sources (used to resolve line numbers in test reports).</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.testSourceDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>

        <!-- ── Class directories ──────────────────────────────────────── -->
        <parameter>
          <name>classesDirectory</name>
          <description>Directory containing compiled main class files to check.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>testClassesDirectory</name>
          <description>Directory containing compiled test class files to check.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.testOutputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip signature checking entirely. User property: animal.sniffer.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.6,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  animal-sniffer:build-signatures                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>build-signatures</name>
      <fullName>org.codehaus.mojo:animal-sniffer-maven-plugin:build-signatures</fullName>
      <description>Builds an API signature file from the project's compiled classes for later use with check.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── Output location ────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the generated signature file is written.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputFileName</name>
          <description>Name of the generated signature file (without extension).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.finalName}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Artifact attachment ────────────────────────────────────── -->
        <parameter>
          <name>attach</name>
          <description>Whether to attach the generated signature file to the project for installation and deployment.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Java home inclusion ────────────────────────────────────── -->
        <parameter>
          <name>includeJavaHome</name>
          <description>Whether to include the JDK runtime classes from java.home in the signature.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>javaHomePatterns</name>
          <description>Glob patterns selecting which jar files under java.home to include in the signature.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Version override ───────────────────────────────────────── -->
        <parameter>
          <name>version</name>
          <description>Overrides the artifact version used when attaching the generated signature file.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.version}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Base signatures ────────────────────────────────────────── -->
        <parameter>
          <name>sign</name>
          <description>List of signature artifact GAVs to include as base signatures when building the signature file.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Signature[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.3,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  animal-sniffer:help                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.codehaus.mojo:animal-sniffer-maven-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
