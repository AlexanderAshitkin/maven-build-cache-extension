<!--
  Parameter catalog for maven-site-plugin.
  Source: https://maven.apache.org/plugins/maven-site-plugin/
  Latest documented version: 4.0.0-M16

  category values:
    functional  - affects artifact content (which files end up in the site,
                  report content, site structure, encoding)
    behavioral  - affects how site generation runs but not the output artifact

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-site-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  site:site                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>site</name>
      <fullName>org.apache.maven.plugins:maven-site-plugin:site</fullName>
      <description>Generates the Maven project site.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Output directory ──────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Directory where the generated site files are written. User property: siteOutputDirectory. Default: ${project.reporting.outputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>generatedSiteDirectory</name>
          <description>Directory containing generated documentation that will be merged with the site source. Default: ${project.build.directory}/generated-site</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/generated-site</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Encoding ──────────────────────────────────────────────── -->
        <parameter>
          <name>inputEncoding</name>
          <description>Character encoding for reading source files. User property: encoding. Default: ${project.build.sourceEncoding}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.sourceEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputEncoding</name>
          <description>Character encoding for writing generated HTML pages. User property: outputEncoding. Default: ${project.reporting.outputEncoding}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.reporting.outputEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Locales ───────────────────────────────────────────────── -->
        <parameter>
          <name>locales</name>
          <description>Comma-separated list of locales (e.g. "en,fr") for which to generate the site. User property: locales. Default: default locale</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Report generation ─────────────────────────────────────── -->
        <parameter>
          <name>generateReports</name>
          <description>Whether to include reports in the site. Default: true</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>reportPlugins</name>
          <description>List of reporting plugin configurations to include when generating the site (legacy mechanism).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>ReportPlugin[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Sitemap ───────────────────────────────────────────────── -->
        <parameter>
          <name>generateSitemap</name>
          <description>Whether to generate a sitemap.html table-of-contents page. Default: false</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>

        <!-- ── Decoration links ──────────────────────────────────────── -->
        <parameter>
          <name>relativizeDecorationLinks</name>
          <description>Make anchor links in the site decoration (menus, breadcrumbs) relative rather than absolute. Default: true</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.3,)</versionRange>
        </parameter>

        <!-- ── Module inheritance ────────────────────────────────────── -->
        <parameter>
          <name>moduleExcludes</name>
          <description>Map of document-type to comma-separated exclusion patterns for filtering site source documents.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>templateDirectory</name>
          <description>Directory containing custom Velocity site template overrides. User property: templateDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>template</name>
          <description>Path to a custom Velocity template for the site skin (overrides the skin JAR template).</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>attributes</name>
          <description>Additional Velocity context attributes (key-value pairs) made available during site rendering.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Map</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>siteDirectory</name>
          <description>Directory containing the site source documents (APT, Markdown, FML, XDOC, etc.). Default: ${basedir}/src/site</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${basedir}/src/site</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>xdocDirectory</name>
          <description>Alternative directory for XDOC documents (deprecated; use siteDirectory). Default: ${basedir}/xdocs</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${basedir}/xdocs</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip site generation entirely. User property: maven.site.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  site:deploy                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>deploy</name>
      <fullName>org.apache.maven.plugins:maven-site-plugin:deploy</fullName>
      <description>Deploys the generated site to the remote server defined in distributionManagement/site.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>inputDirectory</name>
          <description>Directory containing the site to deploy. Default: ${project.reporting.outputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>url</name>
          <description>Deployment URL (overrides distributionManagement/site/url). User property: distributionManagementSiteUrl</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>id</name>
          <description>Server ID in settings.xml to look up deployment credentials. User property: maven.site.deploy.serverId</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the site deployment. User property: maven.site.deploy.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  site:stage                                                         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>stage</name>
      <fullName>org.apache.maven.plugins:maven-site-plugin:stage</fullName>
      <description>Stages the site locally into a staging directory, simulating the deploy layout.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>stagingDirectory</name>
          <description>Directory into which the site will be staged. User property: stagingDirectory. Default: ${project.build.directory}/staging</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/staging</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the staging operation. User property: maven.site.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  site:stage-deploy                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>stage-deploy</name>
      <fullName>org.apache.maven.plugins:maven-site-plugin:stage-deploy</fullName>
      <description>Deploys the staged site to a remote staging server.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>stagingDirectory</name>
          <description>Local staging directory to deploy from. Default: ${project.build.directory}/staging</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/staging</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>stagingSiteURL</name>
          <description>Remote URL for the staging site deployment. User property: stagingSiteURL</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the stage-deploy operation. User property: maven.site.deploy.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  site:attach-descriptor                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>attach-descriptor</name>
      <fullName>org.apache.maven.plugins:maven-site-plugin:attach-descriptor</fullName>
      <description>Attaches the site descriptor (site.xml) to the project as an artifact.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>siteDirectory</name>
          <description>Directory containing the site.xml descriptor. Default: ${basedir}/src/site</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${basedir}/src/site</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip attaching the descriptor. User property: maven.site.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  site:jar                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>jar</name>
      <fullName>org.apache.maven.plugins:maven-site-plugin:jar</fullName>
      <description>Packages the site as a JAR artifact.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>outputDirectory</name>
          <description>Directory containing the generated site to be packaged into the JAR. Default: ${project.reporting.outputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>finalName</name>
          <description>Base name of the generated site JAR. Default: ${project.build.finalName}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.finalName}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>attach</name>
          <description>Whether to attach the site JAR as a project artifact. Default: true</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>archivingEnabled</name>
          <description>Whether JAR archiving is enabled for the site:jar goal. Default: true</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>archive</name>
          <description>Maven Archiver configuration for the site JAR manifest and archive settings.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>MavenArchiveConfiguration</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip the site:jar goal execution. User property: maven.site.skip. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  site:effective-site                                                -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>effective-site</name>
      <fullName>org.apache.maven.plugins:maven-site-plugin:effective-site</fullName>
      <description>Calculates the effective site descriptor (merged from project hierarchy) and displays it.</description>
      <versionRange>[3.0,)</versionRange>
      <parameters>

        <parameter>
          <name>output</name>
          <description>Optional file path to write the effective site descriptor instead of printing to stdout.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  site:run                                                           -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>run</name>
      <fullName>org.apache.maven.plugins:maven-site-plugin:run</fullName>
      <description>Starts a Jetty web server to serve the generated site locally for review.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>port</name>
          <description>Port to run the embedded Jetty server on. User property: port. Default: 8080</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>8080</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>tempWebappDirectory</name>
          <description>Directory where Jetty stages the exploded site webapp. Default: ${project.build.directory}/site-webapp</description>
          <category>behavioral</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/site-webapp</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  site:help                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-site-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. Default: false</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output. Default: 80</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. Default: 2</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
