<!--
  Parameter catalog for maven-scm-publish-plugin.
  Source: https://maven.apache.org/plugins/maven-scm-publish-plugin/
  Latest documented version: 3.3.0
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-scm-publish-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  scm-publish:publish-scm                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>publish-scm</name>
      <fullName>org.apache.maven.plugins:maven-scm-publish-plugin:publish-scm</fullName>
      <description>Publishes a directory of content to an SCM URL (e.g. project site to SVN/GitHub Pages).</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>

        <!-- ── SCM destination ───────────────────────────────────────── -->
        <parameter>
          <name>pubScmUrl</name>
          <description>SCM URL of the publication target (e.g. scm:svn:https://... or scm:git:...). User property: scmpublish.pubScmUrl</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>scmBranch</name>
          <description>Branch to publish to (e.g. gh-pages). User property: scmpublish.scmBranch</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>checkoutDirectory</name>
          <description>Local checkout directory used as a staging area before push. User property: scmpublish.checkoutDirectory</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.build.directory}/scmpublish-checkout</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Source content ────────────────────────────────────────── -->
        <parameter>
          <name>content</name>
          <description>Directory containing the content to publish to SCM. User property: scmpublish.content</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>includes</name>
          <description>Ant-style patterns of files to include in publishing (all files if unset).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>Ant-style patterns of files to exclude from publishing.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>ignorePathsToDelete</name>
          <description>Patterns of paths in SCM that should not be deleted during a publish update.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skipDeletedFiles</name>
          <description>Keep files in SCM that are absent from the publish content instead of deleting them. User property: scmpublish.skipDeletedFiles</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── SCM credentials / server ──────────────────────────────── -->
        <parameter>
          <name>serverId</name>
          <description>Server ID in settings.xml supplying credentials for the publish SCM URL. User property: scmpublish.serverId</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Update strategy ───────────────────────────────────────── -->
        <parameter>
          <name>tryUpdate</name>
          <description>Update an existing checkout rather than always doing a fresh checkout. User property: scmpublish.tryUpdate</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

        <!-- ── Commit options ────────────────────────────────────────── -->
        <parameter>
          <name>checkinComment</name>
          <description>Commit message used when checking published content into SCM. User property: scmpublish.checkinComment</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>Site checkin for project ${project.name}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>automaticRemotePathCreation</name>
          <description>Create missing intermediate SCM paths automatically before publishing. User property: scmpublish.automaticRemotePathCreation</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.1,)</versionRange>
        </parameter>

        <!-- ── Skip ──────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip the scm-publish goal entirely. User property: scmpublish.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  scm-publish:help                                                    -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-scm-publish-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[1.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output.</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[1.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
