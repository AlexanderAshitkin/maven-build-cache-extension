<!--
  Parameter catalog for maven-help-plugin.
  Source: https://maven.apache.org/plugins/maven-help-plugin/
  Latest documented version: 3.5.1

  category values:
    functional  - affects the output file or the content of the captured report
                  (cache must be invalidated on change)
    behavioral  - affects how the goal runs or the verbosity of console output

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-help-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  help:active-profiles                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>active-profiles</name>
      <fullName>org.apache.maven.plugins:maven-help-plugin:active-profiles</fullName>
      <description>Displays the list of active profiles for the current build.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>output</name>
          <description>File path to write active-profiles output to instead of console. User property: output</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  help:all-profiles                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>all-profiles</name>
      <fullName>org.apache.maven.plugins:maven-help-plugin:all-profiles</fullName>
      <description>Displays all available profiles (active and inactive) for the project.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>output</name>
          <description>File path to write all-profiles output to instead of console. User property: output</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  help:describe                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>describe</name>
      <fullName>org.apache.maven.plugins:maven-help-plugin:describe</fullName>
      <description>Describes plugin goal parameters and attributes in detail.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Plugin / goal selection ───────────────────────────────── -->
        <parameter>
          <name>plugin</name>
          <description>Plugin GAV or prefix to describe (e.g. org.apache.maven.plugins:maven-jar-plugin or jar). User property: plugin</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Specific goal name to describe (within the selected plugin). User property: goal</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>mojo</name>
          <description>Alias for 'goal' parameter (deprecated, use 'goal' instead). User property: mojo</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Output detail ─────────────────────────────────────────── -->
        <parameter>
          <name>minimal</name>
          <description>Show minimal information (name, description, bound phase) only. User property: minimal</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>medium</name>
          <description>Show medium information (default detail level). User property: medium</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>detail</name>
          <description>Show full parameter details for the described goal. User property: detail</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Output file ────────────────────────────────────────────── -->
        <parameter>
          <name>outputFile</name>
          <description>File path to write describe output to instead of console. User property: outputFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  help:effective-pom                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>effective-pom</name>
      <fullName>org.apache.maven.plugins:maven-help-plugin:effective-pom</fullName>
      <description>Displays the effective POM as seen by Maven after inheritance and interpolation.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>output</name>
          <description>File path to write the effective POM to instead of console. User property: output</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>verbose</name>
          <description>Include comments with origins of inherited elements in the effective POM. User property: verbose</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  help:effective-settings                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>effective-settings</name>
      <fullName>org.apache.maven.plugins:maven-help-plugin:effective-settings</fullName>
      <description>Displays the effective settings.xml after inheritance and interpolation.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>output</name>
          <description>File path to write effective settings to instead of console. User property: output</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>showPasswords</name>
          <description>Show decrypted passwords in the effective settings output. User property: showPasswords</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  help:evaluate                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>evaluate</name>
      <fullName>org.apache.maven.plugins:maven-help-plugin:evaluate</fullName>
      <description>Evaluates a Maven expression and prints the result.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>expression</name>
          <description>Maven expression to evaluate (e.g. ${project.version}). User property: expression</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>output</name>
          <description>File path to write the evaluation result to instead of console. User property: output</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>forceStdout</name>
          <description>Print the result to stdout even when output file is specified. User property: forceStdout</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  help:system                                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>system</name>
      <fullName>org.apache.maven.plugins:maven-help-plugin:system</fullName>
      <description>Displays system properties and environment variables available to Maven.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>output</name>
          <description>File path to write system info to instead of console. User property: output</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  help:help                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-help-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. User property: detail</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help. User property: goal</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output formatting. User property: lineLength</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. User property: indentSize</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
