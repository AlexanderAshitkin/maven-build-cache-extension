    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  pmd:check                                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>check</name>
      <fullName>org.apache.maven.plugins:maven-pmd-plugin:check</fullName>
      <description>Fails the build if PMD violations exceed configured thresholds.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>failurePriority</name>
          <description>Minimum PMD priority (1-5) that causes build failure. User property: pmd.failurePriority</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>5</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>maxAllowedViolations</name>
          <description>Maximum number of PMD violations allowed before failing. User property: pmd.maxAllowedViolations</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>0</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.10.0,)</versionRange>
        </parameter>
        <parameter>
          <name>printFailingErrors</name>
          <description>Print failing PMD violations to console. User property: pmd.printFailingErrors</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludeFromFailureFile</name>
          <description>File listing violations to exclude from failure checks. User property: pmd.excludeFromFailureFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip PMD check entirely. User property: pmd.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>
        <parameter>
          <name>skipPmdError</name>
          <description>Skip check if PMD analysis itself encounters errors. User property: skipPmdError</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  pmd:cpd                                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>cpd</name>
      <fullName>org.apache.maven.plugins:maven-pmd-plugin:cpd</fullName>
      <description>Runs CPD (Copy/Paste Detector) and generates a duplication report.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <parameter>
          <name>minimumTokens</name>
          <description>Minimum token count to consider code a duplication. User property: minimumTokens</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>100</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>outputDirectory</name>
          <description>Output directory for CPD report. Default: ${project.reporting.outputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>format</name>
          <description>CPD report format: xml, text, csv. User property: format</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>List of Ant-style patterns for source files to exclude from CPD.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>sourceEncoding</name>
          <description>Source file encoding for CPD analysis. User property: encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.sourceEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.3,)</versionRange>
        </parameter>
        <parameter>
          <name>includeTests</name>
          <description>Include test source directories in CPD analysis. User property: includeTests</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>skipEmptyReport</name>
          <description>Skip CPD report when no duplications are found. User property: cpd.skipEmptyReport</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1,)</versionRange>
        </parameter>
        <parameter>
          <name>skip</name>
          <description>Skip CPD analysis entirely. User property: cpd.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>

      </parameters>
    </goal>

