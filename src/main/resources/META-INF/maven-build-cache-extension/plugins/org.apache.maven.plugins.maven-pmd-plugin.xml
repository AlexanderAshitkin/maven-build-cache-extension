<!--
  Parameter catalog for maven-pmd-plugin.
  Source: https://maven.apache.org/plugins/maven-pmd-plugin/
  Latest documented version: 3.26.0

  category values:
    functional  - affects which violations are found or the report content
                  (cache must be invalidated on change)
    behavioral  - affects how analysis runs but not which violations are found

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-pmd-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  pmd:pmd                                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>pmd</name>
      <fullName>org.apache.maven.plugins:maven-pmd-plugin:pmd</fullName>
      <description>Runs PMD static analysis and generates a report.</description>
      <versionRange>[2.0,)</versionRange>
      <parameters>

        <!-- ── Output / reporting ─────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Output directory for generated reports. Default: ${project.reporting.outputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>format</name>
          <description>Report format: xml, html, txt, csv, etc. User property: format</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>linkXRef</name>
          <description>Link PMD violations to generated cross-reference HTML source. User property: linkXRef</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>skipEmptyReport</name>
          <description>Skip report generation when no violations are found. User property: pmd.skipEmptyReport</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.1,)</versionRange>
        </parameter>

        <!-- ── Source encoding / language ────────────────────────────── -->
        <parameter>
          <name>sourceEncoding</name>
          <description>Source file encoding. User property: encoding</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.sourceEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.3,)</versionRange>
        </parameter>
        <parameter>
          <name>targetJdk</name>
          <description>Target JDK version for PMD analysis (e.g. 1.8, 11, 17). User property: targetJdk</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${maven.compiler.target}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── Rule configuration ─────────────────────────────────────── -->
        <parameter>
          <name>rulesets</name>
          <description>Rulesets to apply (file paths, URLs, or built-in ruleset names).</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String[]</type>
          <defaultValue>rulesets/java/quickstart.xml</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>

        <!-- ── File include/exclude ───────────────────────────────────── -->
        <parameter>
          <name>includes</name>
          <description>List of Ant-style patterns for source files to include in PMD analysis.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludes</name>
          <description>List of Ant-style patterns for source files to exclude from PMD analysis.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>excludeRoots</name>
          <description>Source root directories to exclude from PMD analysis entirely.</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File[]</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>
        <parameter>
          <name>excludeFromFailureFile</name>
          <description>File listing violations to exclude from failure checks. User property: pmd.excludeFromFailureFile</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>

        <!-- ── Test sources ───────────────────────────────────────────── -->
        <parameter>
          <name>includeTests</name>
          <description>Include test source directories in PMD analysis. User property: includeTests</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.2,)</versionRange>
        </parameter>

        <!-- ── Type resolution ────────────────────────────────────────── -->
        <parameter>
          <name>typeResolution</name>
          <description>Enable type resolution for deeper analysis using project classpath. User property: pmd.typeResolution</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>true</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.7.1,)</versionRange>
        </parameter>

        <!-- ── Analysis cache ─────────────────────────────────────────── -->
        <parameter>
          <name>analysisCache</name>
          <description>Enable incremental analysis cache to speed up repeated runs. User property: pmd.analysisCache</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.8,)</versionRange>
        </parameter>
        <parameter>
          <name>analysisCacheLocation</name>
          <description>Location of the incremental analysis cache file. User property: pmd.analysisCacheLocation</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.directory}/pmd/pmd.cache</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.8,)</versionRange>
        </parameter>

        <!-- ── Benchmark / verbosity ──────────────────────────────────── -->
        <parameter>
          <name>benchmark</name>
          <description>Show benchmark timings for PMD rules. User property: benchmark</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[2.0,)</versionRange>
        </parameter>
        <parameter>
          <name>verbose</name>
          <description>Print debug information during PMD analysis. User property: pmd.verbose</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.0,)</versionRange>
        </parameter>

        <!-- ── Skip ───────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip PMD analysis entirely. User property: pmd.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[2.1,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
