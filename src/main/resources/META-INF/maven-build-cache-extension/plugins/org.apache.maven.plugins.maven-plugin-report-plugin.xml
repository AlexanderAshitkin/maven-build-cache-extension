<!--
  Parameter catalog for maven-plugin-report-plugin.
  Source: https://maven.apache.org/plugins/maven-plugin-report-plugin/
  Latest documented version: 3.15.1

  category values:
    functional  - affects the generated plugin documentation report content
    behavioral  - affects how the report mojo runs but not the output content

  envSpecific: true if the parameter commonly carries file-system paths or
               machine-specific values that differ across environments.
-->
<plugin-catalog>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-plugin-report-plugin</artifactId>
  <goals>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  plugin-report:report                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>report</name>
      <fullName>org.apache.maven.plugins:maven-plugin-report-plugin:report</fullName>
      <description>Generates the plugin descriptor report for Maven plugin projects.</description>
      <versionRange>[3.6.4,)</versionRange>
      <parameters>

        <!-- ── Output ─────────────────────────────────────────────────── -->
        <parameter>
          <name>outputDirectory</name>
          <description>Output directory for the generated report. Default: ${project.reporting.outputDirectory}</description>
          <category>functional</category>
          <envSpecific>true</envSpecific>
          <type>File</type>
          <defaultValue>${project.reporting.outputDirectory}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>

        <!-- ── Encoding ───────────────────────────────────────────────── -->
        <parameter>
          <name>encoding</name>
          <description>Source file encoding for reading plugin descriptors. Default: ${project.build.sourceEncoding}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.build.sourceEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>outputEncoding</name>
          <description>Encoding of the generated report output. Default: ${project.reporting.outputEncoding}</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <defaultValue>${project.reporting.outputEncoding}</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>

        <!-- ── Report content ─────────────────────────────────────────── -->
        <parameter>
          <name>requirements</name>
          <description>Maven and JDK requirement strings shown in the generated report.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>Requirements</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>extractors</name>
          <description>Ordered list of extractor IDs (java, bsh, jelly) for descriptor extraction.</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>List</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>goalPrefix</name>
          <description>Plugin goal prefix override used in the report. User property: goalPrefix</description>
          <category>functional</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>

        <!-- ── Skip ───────────────────────────────────────────────────── -->
        <parameter>
          <name>skip</name>
          <description>Skip plugin report generation entirely. User property: maven.plugin.report.skip</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>true</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>

      </parameters>
    </goal>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!--  plugin-report:help                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <goal>
      <name>help</name>
      <fullName>org.apache.maven.plugins:maven-plugin-report-plugin:help</fullName>
      <description>Displays help information on available goals and parameters.</description>
      <versionRange>[3.6.4,)</versionRange>
      <parameters>
        <parameter>
          <name>detail</name>
          <description>Show parameter details for the specified goal. User property: detail</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>boolean</type>
          <defaultValue>false</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>goal</name>
          <description>Name of the goal for which to show detailed help. User property: goal</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>String</type>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>lineLength</name>
          <description>Maximum line length for help output formatting. User property: lineLength</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>80</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>
        <parameter>
          <name>indentSize</name>
          <description>Number of spaces per indentation level in help output. User property: indentSize</description>
          <category>behavioral</category>
          <envSpecific>false</envSpecific>
          <type>int</type>
          <defaultValue>2</defaultValue>
          <skipProperty>false</skipProperty>
          <versionRange>[3.6.4,)</versionRange>
        </parameter>
      </parameters>
    </goal>

  </goals>
</plugin-catalog>
